---
import Layout from '../layouts/Layout.astro';
import ReadingTime from '../components/ReadingTime.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
// 按日期降序排列
const sortedPosts = posts.sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<Layout title="文章 - fffg" description="技术文章与分享">
  <section>
    <h1 class="mb-8 text-3xl font-bold text-text">文章</h1>
    <div class="space-y-6">
      {
        sortedPosts.map((post) => (
          <article class="group relative rounded-xl border border-border bg-card p-6 transition-all hover:border-primary/30 hover:shadow-md">
            <div class="mb-2 flex flex-wrap items-center gap-2">
              <time class="text-xs text-text-muted">{post.data.date}</time>
              <span class="text-text-muted">·</span>
              <ReadingTime content={post.body} />
            </div>
            <h2 class="mb-2 text-xl font-semibold text-text">
              <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="after:absolute after:inset-0">
                {post.data.title}
              </a>
            </h2>
            <p class="text-sm leading-relaxed text-text-muted">
              {post.data.description}
            </p>
            {
              post.data.tags && post.data.tags.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {post.data.tags.map((tag: string) => (
                    <span class="rounded-full border border-border bg-card px-2 py-0.5 text-xs text-text-muted">
                      #{tag}
                    </span>
                  ))}
                </div>
              )
            }
          </article>
        ))
      }
    </div>
  </section>
</Layout>
