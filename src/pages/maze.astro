---
import Layout from '../layouts/Layout.astro';
import { encryptSlug } from '../lib/slug-crypto';
import { getVisibleMazeEntries } from '../data/maze';

const entries = getVisibleMazeEntries();
const sortedEntries = entries.sort((a, b) => b.date.localeCompare(a.date));
const base = import.meta.env.BASE_URL;

// 收集所有标签
const tagMap = new Map<string, number>();
for (const entry of entries) {
  for (const tag of entry.tags) {
    tagMap.set(tag, (tagMap.get(tag) || 0) + 1);
  }
}
const allTags = Array.from(tagMap.entries()).map(([name, count]) => ({ name, count }));
---

<Layout title="迷宫 - fffg" description="加密路由的隐藏页面集合">
  <section>
    <h1 class="mb-3 text-2xl font-bold text-text sm:text-3xl">迷宫</h1>
    <p class="mb-6 text-sm text-text-muted">
      所有页面的路由均已加密，无法通过 URL 直接访问。
    </p>

    <!-- 标签过滤 -->
    <div class="mb-6 flex flex-wrap gap-2" id="maze-tag-filter">
      <button class="tag-filter-btn active" data-tag="all">全部</button>
      {allTags.map(({ name, count }) => (
        <button class="tag-filter-btn" data-tag={name}>
          #{name} ({count})
        </button>
      ))}
    </div>

    <div class="space-y-6">
      {
        sortedEntries.map((entry) => {
          const encryptedSlug = encryptSlug(entry.id);
          return (
            <article
              class="group relative rounded-xl border border-border bg-card p-6 transition-all hover:border-accent/30 hover:shadow-md"
              data-tags={entry.tags.join(' ')}
            >
              <div class="mb-2 flex flex-wrap items-center gap-2">
                <time class="text-xs text-text-muted">{entry.date}</time>
                <span class="text-text-muted">·</span>
                <span class="text-xs text-accent">🔒 路由已加密</span>
              </div>
              <h2 class="mb-2 text-xl font-semibold text-text">
                <a href={`${base}/maze/${encryptedSlug}`} class="after:absolute after:inset-0">
                  {entry.title}
                </a>
              </h2>
              <p class="text-sm leading-relaxed text-text-muted">
                {entry.description}
              </p>
              {
                entry.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {entry.tags.map((tag: string) => (
                      <span class="rounded-full border border-border bg-card px-2 py-0.5 text-xs text-text-muted">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )
              }
            </article>
          );
        })
      }
    </div>
  </section>
</Layout>

<script>
  // 标签过滤功能
  const filterBtns = document.querySelectorAll('#maze-tag-filter .tag-filter-btn');
  const articles = document.querySelectorAll('article[data-tags]');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag;

      // 更新按钮状态
      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      // 过滤文章
      articles.forEach((article) => {
        if (tag === 'all') {
          article.style.display = '';
        } else {
          const tags = article.dataset.tags || '';
          article.style.display = tags.includes(tag) ? '' : 'none';
        }
      });
    });
  });
</script>
