---
import Layout from '../layouts/Layout.astro';
import { encryptSlug } from '../lib/slug-crypto';
import type { RoomExport } from '../data/maze';
import { mazeConfig } from '../data/maze-config.generated';

// 收集所有房间的导出数据
const roomModules = import.meta.glob('/src/pages/maze/_rooms/*.astro', { eager: true });
const allRooms: RoomExport[] = Object.values(roomModules).map(
  (mod: unknown) => (mod as { room: RoomExport }).room,
);

const minimalRoom = allRooms.find((r) => r.id === 'minimal');
const base = import.meta.env.BASE_URL;

// 入口链接：使用 mazeConfig 中随机分配的起点房间
// 每次构建后起点房间可能不同，因此迷宫入口也随之变化
const entrySlug = encryptSlug(mazeConfig.startRoomId, mazeConfig.mazeSalt);
const minimalSlug = minimalRoom ? encryptSlug('minimal', mazeConfig.mazeSalt) : '';
---

<Layout title="迷宫 - fffg" description="加密路由的隐藏页面集合" hideScrollButtons={true}>
  <section>
    <h1 class="mb-3 text-2xl font-bold text-text sm:text-3xl">迷宫</h1>

    <!-- 迷宫入口卡片 -->
    <div class="mb-8">
      <a
        href={`${base}/maze/${entrySlug}`}
        class="entry-card group relative flex flex-col items-center gap-3 rounded-2xl border-2 border-accent/30 bg-gradient-to-br from-accent/5 to-primary/5 p-8 text-center transition-all hover:border-accent hover:shadow-lg hover:shadow-accent/10"
      >
        <span class="entry-icon text-4xl">🏰</span>
        <span class="entry-title text-xl font-bold text-text">进入迷宫</span>
        <span class="entry-desc text-sm text-text-muted">隐藏着无数秘密与挑战，等待勇者探索</span>
        <span class="entry-arrow mt-2 text-2xl text-accent transition-transform group-hover:translate-x-1">→</span>
      </a>
    </div>

    <!-- 开发入口：仅显示 minimal 链接 -->
    {
      minimalRoom && (
        <div class="mt-16 text-center">
          <a
            href={`${base}/maze/${minimalSlug}`}
            class="dev-link"
          >
            <span class="dev-badge">DEV</span>
            最简界面
          </a>
        </div>
      )
    }
  </section>
</Layout>

<style>
  .entry-card {
    text-decoration: none;
  }
  .entry-icon {
    animation: float 3s ease-in-out infinite;
  }
  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-8px); }
  }
  .dev-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    opacity: 0.4;
    transition: opacity 0.2s;
  }
  .dev-link:hover {
    opacity: 1;
    color: var(--color-accent);
  }
  .dev-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.125rem 0.5rem;
    font-size: 0.6875rem;
    font-weight: 700;
    color: #f59e0b;
    background: color-mix(in srgb, #f59e0b 15%, transparent);
    border: 1px solid color-mix(in srgb, #f59e0b 30%, transparent);
    border-radius: 9999px;
    letter-spacing: 0.05em;
  }
</style>
