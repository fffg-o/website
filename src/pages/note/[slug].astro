---
import Layout from '../../layouts/Layout.astro';
import TOC from '../../components/TOC.astro';
import ReadingTime from '../../components/ReadingTime.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const noteEntries = await getCollection('notes');
  return noteEntries.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// 获取所有随笔，按日期升序排列（从古至今）
const allNotes = await getCollection('notes');
const sortedNotes = allNotes.sort((a, b) => a.data.date.localeCompare(b.data.date));

// 查找当前文章在排序后列表中的索引
const currentIndex = sortedNotes.findIndex(
  (note) => note.id === entry.id
);

// 获取上一篇（更早）和下一篇（更新）的文章
const prevNote = currentIndex > 0 ? sortedNotes[currentIndex - 1] : null;
const nextNote = currentIndex < sortedNotes.length - 1 ? sortedNotes[currentIndex + 1] : null;

const base = import.meta.env.BASE_URL;
---

<Layout title={`${entry.data.title} - fffg`} description={entry.data.description}>
  <div class="blog-page">
    <!-- 文章主体 -->
    <article class="blog-article prose prose-zinc dark:prose-invert">
      <header class="mb-6 not-prose sm:mb-8">
        <h1 class="mb-3 text-2xl font-bold text-text sm:text-3xl">{entry.data.title}</h1>
        <div class="flex flex-wrap items-center gap-3">
          <time class="text-sm text-text-muted">{entry.data.date}</time>
          <span class="text-text-muted">·</span>
          <ReadingTime content={entry.body} />
        </div>
        <!-- 标签 -->
        {
          entry.data.tags && entry.data.tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-2">
              {entry.data.tags.map((tag: string) => (
                <span class="rounded-full border border-border bg-card px-2.5 py-0.5 text-xs text-text-muted">
                  #{tag}
                </span>
              ))}
            </div>
          )
        }
      </header>
      <Content />
    </article>

    <!-- 桌面端 TOC 侧边栏 -->
    <aside class="blog-toc-sidebar">
      <TOC />
    </aside>
  </div>

  <!-- 上一篇 / 下一篇文章导航 -->
  <nav class="note-prev-next not-prose" aria-label="随笔导航">
    {
      prevNote ? (
        <a href={`${base}/note/${prevNote.id.replace(/\.md$/, '')}`} class="note-nav-link note-nav-prev">
          <span class="note-nav-arrow">←</span>
          <span class="note-nav-text">
            <span class="note-nav-label">上一篇</span>
            <span class="note-nav-title">{prevNote.data.title}</span>
          </span>
        </a>
      ) : (
        <div class="note-nav-placeholder"></div>
      )
    }
    {
      nextNote ? (
        <a href={`${base}/note/${nextNote.id.replace(/\.md$/, '')}`} class="note-nav-link note-nav-next">
          <span class="note-nav-text note-nav-text-right">
            <span class="note-nav-label">下一篇</span>
            <span class="note-nav-title">{nextNote.data.title}</span>
          </span>
          <span class="note-nav-arrow">→</span>
        </a>
      ) : (
        <div class="note-nav-placeholder"></div>
      )
    }
  </nav>
</Layout>
