---
import Layout from '../../layouts/Layout.astro';
import TOC from '../../components/TOC.astro';
import ReadingTime from '../../components/ReadingTime.astro';
import SeriesNav from '../../components/SeriesNav.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} - fffg`} description={entry.data.description}>
  <!-- 移动端 TOC （在文章上方） -->
  <div class="mb-6 lg:hidden">
    <TOC />
  </div>

  <div class="flex gap-8 lg:gap-12">
    <!-- 文章主体 -->
    <article class="prose prose-zinc min-w-0 flex-1 dark:prose-invert">
      <header class="mb-8 not-prose">
        <h1 class="mb-3 text-3xl font-bold text-text">{entry.data.title}</h1>
        <div class="flex flex-wrap items-center gap-3">
          <time class="text-sm text-text-muted">{entry.data.date}</time>
          <span class="text-text-muted">·</span>
          <ReadingTime content={entry.body} />
        </div>
        <!-- 标签 -->
        {
          entry.data.tags && entry.data.tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-2">
              {entry.data.tags.map((tag: string) => (
                <span class="rounded-full border border-border bg-card px-2.5 py-0.5 text-xs text-text-muted">
                  #{tag}
                </span>
              ))}
            </div>
          )
        }
      </header>
      <Content />
    </article>

    <!-- 桌面端 TOC 侧边栏 -->
    <aside class="hidden w-56 shrink-0 lg:block xl:w-64">
      <TOC />
    </aside>
  </div>

  <!-- 系列导航 -->
  <SeriesNav post={entry} />
</Layout>
