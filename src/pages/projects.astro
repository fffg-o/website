---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<Layout title="项目 - fffg" description="开源项目与作品">
  <section>
    <h1 class="mb-8 text-3xl font-bold text-text">项目</h1>
    <div class="grid gap-6 sm:grid-cols-2">
      {
        projects.map((project) => (
          <article class="group rounded-xl border border-border bg-card p-6 transition-all hover:border-primary/30 hover:shadow-md">
            <h2 class="mb-2 text-lg font-semibold text-text">
              {project.data.link ? (
                <a href={project.data.link} class="after:absolute after:inset-0">
                  {project.data.title}
                </a>
              ) : (
                project.data.title
              )}
            </h2>
            <p class="mb-4 text-sm leading-relaxed text-text-muted">
              {project.data.description}
            </p>
            <div class="flex flex-wrap gap-2">
              {project.data.tags.map((tag: string) => (
                <span class="rounded-md bg-surface px-2.5 py-1 text-xs font-medium text-text-muted">
                  {tag}
                </span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</Layout>
