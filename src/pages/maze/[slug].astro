---
// ============================================================
// 迷宫路由处理器
//
// 职责：
// 1. 收集 _rooms/*.astro 中导出的 id
// 2. 生成加密路由（getStaticPaths）
// 3. 从生成的迷宫配置中读取传送门数据
// 4. 使用 RoomLayout 包裹，动态加载并渲染对应的房间组件
//
// 原则：路由不关心页面渲染细节，只负责加密路径/传递信息，
//       确保页面拥有最大的可扩展性。
// ============================================================
import RoomLayout from '../../layouts/RoomLayout.astro';
import { encryptSlug } from '../../lib/slug-crypto';
import type { RoomExport, Portal } from '../../data/maze';
import { mazeConfig } from '../../data/maze-config.generated';

// getStaticPaths 内部收集房间数据，确保作用域正确
export async function getStaticPaths() {
  const roomModules = import.meta.glob('/src/pages/maze/_rooms/*.astro', { eager: true });
  const allRooms: RoomExport[] = Object.values(roomModules).map(
    (mod: unknown) => (mod as { room: RoomExport }).room,
  );

  return allRooms.map((room) => {
    const encryptedSlug = encryptSlug(room.id);
    return {
      params: { slug: encryptedSlug },
      props: { room },
    };
  });
}

const { room } = Astro.props;
const base = import.meta.env.BASE_URL;

// 从生成的迷宫配置中读取传送门
const portals: Portal[] = mazeConfig.portalsMap[room.id] ?? [];

// 动态加载房间组件（eager glob 在编译时解析，自动包含新增房间）
const roomModules = import.meta.glob('/src/pages/maze/_rooms/*.astro', { eager: true }) as Record<string, { default: any; room: RoomExport }>;
const RoomComponent = roomModules[`/src/pages/maze/_rooms/${room.id}.astro`]?.default;
---

<RoomLayout>
  {RoomComponent && <RoomComponent room={room} baseUrl={base} portals={portals} />}
</RoomLayout>
