---
import Layout from '../../layouts/Layout.astro';
import TOC from '../../components/TOC.astro';
import { encryptSlug } from '../../lib/slug-crypto';
import { getVisibleMazeEntries } from '../../data/maze';
import { Marked } from 'marked';

// 在构建时预生成所有迷宫页面的加密路由
export async function getStaticPaths() {
  const entries = getVisibleMazeEntries();
  return entries.map((entry) => {
    const encryptedSlug = encryptSlug(entry.id);
    return {
      params: { slug: encryptedSlug },
      props: { entry, encryptedSlug },
    };
  });
}

const { entry, encryptedSlug } = Astro.props;

// 获取所有可见条目，用于上下篇导航
const allVisible = getVisibleMazeEntries().sort((a, b) =>
  a.date.localeCompare(b.date)
);
const currentIndex = allVisible.findIndex((e) => e.id === entry.id);
const prevEntry = currentIndex > 0 ? allVisible[currentIndex - 1] : null;
const nextEntry = currentIndex < allVisible.length - 1 ? allVisible[currentIndex + 1] : null;

const base = import.meta.env.BASE_URL;

// 将 Markdown 渲染为 HTML
const marked = new Marked();
const contentHtml = await marked.parse(entry.content);
---

<Layout title={`${entry.title} - 迷宫 - fffg`} description={entry.description}>
  <div class="blog-page">
    <!-- 文章主体 -->
    <article class="blog-article prose prose-zinc dark:prose-invert">
      <header class="mb-6 not-prose sm:mb-8">
        <h1 class="mb-3 text-2xl font-bold text-text sm:text-3xl">{entry.title}</h1>
        <div class="flex flex-wrap items-center gap-3">
          <time class="text-sm text-text-muted">{entry.date}</time>
          <span class="text-text-muted">·</span>
          <span class="inline-flex items-center gap-1 rounded-md bg-accent/10 px-2 py-0.5 text-xs text-accent">
            <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            路由已加密
          </span>
        </div>
        <!-- 标签 -->
        {
          entry.tags.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-2">
              {entry.tags.map((tag: string) => (
                <span class="rounded-full border border-border bg-card px-2.5 py-0.5 text-xs text-text-muted">
                  #{tag}
                </span>
              ))}
            </div>
          )
        }
      </header>

      <!-- 渲染后的 Markdown 内容 -->
      <div set:html={contentHtml} />
    </article>

    <!-- 桌面端 TOC 侧边栏 -->
    <aside class="blog-toc-sidebar">
      <TOC />
    </aside>
  </div>

  <!-- 上一篇 / 下一篇文章导航（路由同样加密） -->
  <nav class="note-prev-next not-prose" aria-label="迷宫导航">
    {
      prevEntry ? (
        <a href={`${base}/maze/${encryptSlug(prevEntry.id)}`} class="note-nav-link note-nav-prev">
          <span class="note-nav-arrow">←</span>
          <span class="note-nav-text">
            <span class="note-nav-label">上一篇</span>
            <span class="note-nav-title">{prevEntry.title}</span>
          </span>
        </a>
      ) : (
        <div class="note-nav-placeholder"></div>
      )
    }
    {
      nextEntry ? (
        <a href={`${base}/maze/${encryptSlug(nextEntry.id)}`} class="note-nav-link note-nav-next">
          <span class="note-nav-text note-nav-text-right">
            <span class="note-nav-label">下一篇</span>
            <span class="note-nav-title">{nextEntry.title}</span>
          </span>
          <span class="note-nav-arrow">→</span>
        </a>
      ) : (
        <div class="note-nav-placeholder"></div>
      )
    }
  </nav>
</Layout>
