---
import MazeMap from "../../../components/MazeMap.astro";
import type { RoomExport } from "../../../data/maze";
import type { Portal } from "../../../data/maze";
import { getMazeUrl } from "../../../lib/maze-url";
import { mazeConfig } from "../../../data/maze-config.generated";

export const room: RoomExport = {
  id: "conway",
  portalSlots: [
    { label: "", description: "" },
    { label: "", description: "" },
  ],
};

interface Props {
  room: RoomExport;
  baseUrl: string;
  portals: Portal[];
}
const { room: meta, baseUrl, portals: externalPortals } = Astro.props;

function portalHref(targetId: string): string {
  return `${baseUrl}${getMazeUrl(targetId, mazeConfig.mazeSalt)}?from=${meta.id}`;
}
---

<MazeMap currentRoomId={meta.id} />

<div class="blog-page">
  <article class="blog-article prose prose-zinc dark:prose-invert">
    <div class="puzzle-room" data-puzzle-id={meta.id}>
      <div class="puzzle-area" id="puzzle-area">
        <!-- 游戏网格 -->
        <div class="conway-grid-container">
          <div class="conway-grid" id="conway-grid"></div>
        </div>

        <!-- 控制按钮 -->
        <div class="conway-controls">
          <button class="puzzle-btn puzzle-btn-secondary" id="reset-btn" >🔄</button>
          <button class="puzzle-btn puzzle-btn-secondary" id="start-btn" >▶️</button>
          <button class="puzzle-btn puzzle-btn-secondary" id="pause-btn"  disabled>⏸️</button>
        </div>
      </div>

      <!-- 传送门区域：并排放置 -->
      <div class="portals-row" id="conway-portals-row">
        {
          externalPortals.filter((_, i) => i === 0).map((portal: Portal) => (
            <a
              href={portalHref(portal.targetId)}
              class="portal-link"
              id="room-portals-still"
              style="display:none"
            >
              <div class="portal-visual portal-visual-still">
                <svg viewBox="0 0 100 100" class="portal-svg">
                  <defs>
                    <radialGradient id="portal-glow-still" cx="50%" cy="50%" r="50%">
                      <stop offset="0%" stop-color="#fbbf24" stop-opacity="0.8"></stop>
                      <stop offset="60%" stop-color="#f59e0b" stop-opacity="0.3"></stop>
                      <stop offset="100%" stop-color="#f59e0b" stop-opacity="0"></stop>
                    </radialGradient>
                  </defs>
                  <circle cx="50" cy="50" r="45" fill="url(#portal-glow-still)" class="portal-pulse">
                    <animate attributeName="r" values="40;48;40" dur="2s" repeatCount="indefinite"></animate>
                  </circle>
                  <circle cx="50" cy="50" r="20" fill="none" stroke="#fbbf24" stroke-width="2" opacity="0.6">
                    <animate attributeName="r" values="20;35;20" dur="3s" repeatCount="indefinite"></animate>
                    <animate attributeName="opacity" values="0.6;0.2;0.6" dur="3s" repeatCount="indefinite"></animate>
                  </circle>
                  <circle cx="50" cy="50" r="10" fill="none" stroke="#fde68a" stroke-width="1.5" opacity="0.4">
                    <animate attributeName="r" values="10;40;10" dur="4s" repeatCount="indefinite"></animate>
                    <animate attributeName="opacity" values="0.4;0.1;0.4" dur="4s" repeatCount="indefinite"></animate>
                  </circle>
                  <text x="50" y="55" text-anchor="middle" fill="#fbbf24" font-size="14" font-weight="bold">✦</text>
                </svg>
              </div>
            </a>
          ))
        }
        {
          externalPortals.filter((_, i) => i === 1).map((portal: Portal) => (
            <a
              href={portalHref(portal.targetId)}
              class="portal-link"
              id="room-portals-osc"
              style="display:none"
            >
              <div class="portal-visual portal-visual-osc">
                <svg viewBox="0 0 100 100" class="portal-svg">
                  <defs>
                    <radialGradient id="portal-glow-osc" cx="50%" cy="50%" r="50%">
                      <stop offset="0%" stop-color="#34d399" stop-opacity="0.8"></stop>
                      <stop offset="60%" stop-color="#10b981" stop-opacity="0.3"></stop>
                      <stop offset="100%" stop-color="#10b981" stop-opacity="0"></stop>
                    </radialGradient>
                  </defs>
                  <circle cx="50" cy="50" r="45" fill="url(#portal-glow-osc)" class="portal-pulse">
                    <animate attributeName="r" values="40;48;40" dur="2s" repeatCount="indefinite"></animate>
                  </circle>
                  <circle cx="50" cy="50" r="20" fill="none" stroke="#34d399" stroke-width="2" opacity="0.6">
                    <animate attributeName="r" values="20;35;20" dur="3s" repeatCount="indefinite"></animate>
                    <animate attributeName="opacity" values="0.6;0.2;0.6" dur="3s" repeatCount="indefinite"></animate>
                  </circle>
                  <circle cx="50" cy="50" r="10" fill="none" stroke="#6ee7b7" stroke-width="1.5" opacity="0.4">
                    <animate attributeName="r" values="10;40;10" dur="4s" repeatCount="indefinite"></animate>
                    <animate attributeName="opacity" values="0.4;0.1;0.4" dur="4s" repeatCount="indefinite"></animate>
                  </circle>
                  <text x="50" y="55" text-anchor="middle" fill="#34d399" font-size="14" font-weight="bold">∞</text>
                </svg>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </article>
  <aside class="blog-toc-sidebar"></aside>
</div>

<style is:global>
  /* ===== 网格容器 ===== */
  .conway-grid-container {
    display: flex;
    justify-content: center;
    padding: 1rem;
    margin: 0.5rem auto;
    background: color-mix(in srgb, var(--color-border) 30%, transparent);
    border-radius: 1.5rem;
    max-width: 100%;
    width: 100%;
    overflow-x: auto;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
  }

  .conway-grid {
    display: grid;
    gap: 1px;
    background: color-mix(in srgb, var(--color-border) 50%, transparent);
    border-radius: 0.375rem;
    user-select: none;
    -webkit-user-select: none;
    touch-action: manipulation;
  }

  /* 网格容器滚动条微调 */
  .conway-grid-container::-webkit-scrollbar {
    height: 6px;
    width: 6px;
  }
  .conway-grid-container::-webkit-scrollbar-track {
    background: transparent;
  }
  .conway-grid-container::-webkit-scrollbar-thumb {
    background: color-mix(in srgb, var(--color-border) 60%, transparent);
    border-radius: 3px;
  }

  /* ===== 单元格 ===== */
  .conway-cell {
    width: 14px;
    height: 14px;
    border: none;
    border-radius: 2px;
    cursor: pointer;
    padding: 0;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    transition: background 0.08s ease, transform 0.08s ease, box-shadow 0.15s ease;
    background: color-mix(in srgb, var(--color-border) 15%, transparent);
  }

  .conway-cell:hover {
    transform: scale(1.15);
    z-index: 1;
    box-shadow: 0 0 4px var(--color-primary);
  }

  .conway-cell:active {
    transform: scale(0.9);
  }

  .conway-cell.alive {
    background: var(--color-primary);
    box-shadow: 0 0 3px color-mix(in srgb, var(--color-primary) 40%, transparent);
  }

  .conway-cell.alive:hover {
    box-shadow: 0 0 8px color-mix(in srgb, var(--color-primary) 60%, transparent);
  }

  .conway-cell.just-born {
    background: #34d399;
    box-shadow: 0 0 4px rgba(52, 211, 153, 0.4);
  }

  .conway-cell.just-died {
    background: color-mix(in srgb, var(--color-border) 25%, transparent);
    animation: cell-fade 0.3s ease-out forwards;
  }

  @keyframes cell-fade {
    0% { opacity: 0.6; }
    100% { opacity: 1; }
  }

  /* ===== 图案检测发光 ===== */
  @keyframes pattern-glow {
    0%   { box-shadow: 0 0 3px var(--color-accent, #fbbf24), 0 0 8px var(--color-accent, #fbbf24); }
    50%  { box-shadow: 0 0 10px var(--color-accent, #fbbf24), 0 0 24px var(--color-accent, #fbbf24); }
    100% { box-shadow: 0 0 3px var(--color-accent, #fbbf24), 0 0 8px var(--color-accent, #fbbf24); }
  }
  .conway-cell.pattern-glow {
    animation: pattern-glow 0.6s ease-in-out;
    z-index: 2;
  }

  /* ===== 控制按钮区域 ===== */
  .conway-controls {
    display: flex;
    justify-content: center;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  /* ===== 传送门颜色变体（房间特有） ===== */
  .portal-visual-osc .portal-svg {
    filter: drop-shadow(0 0 30px rgba(52, 211, 153, 0.15));
  }

  /* ===== 小屏幕适配 ===== */
  @media (max-width: 639px) {
    .conway-grid-container {
      padding: 0.5rem;
      margin: 0.25rem -0.5rem;
      border-radius: 1rem;
    }

    .conway-cell {
      width: 10px;
      height: 10px;
    }

    .conway-controls {
      gap: 0.5rem;
    }
  }

  @media (max-width: 400px) {
    .conway-cell {
      width: 8px;
      height: 8px;
      border-radius: 1px;
    }
  }
</style>

<script>
// @ts-nocheck
(function () {
  "use strict";

  // ============================================================
  // 康威生命游戏核心逻辑
  // ============================================================

  // ===== 常量配置 =====
  var COLS = 65;
  var ROWS = 46;
  var INTERVAL_MS = 180;

  // ===== DOM 元素 =====
  var gridEl = document.getElementById("conway-grid");
  var resetBtn = document.getElementById("reset-btn");
  var startBtn = document.getElementById("start-btn");
  var pauseBtn = document.getElementById("pause-btn");
  var portalsStill = document.getElementById("room-portals-still");
  var portalsOsc = document.getElementById("room-portals-osc");

  // ===== 游戏状态 =====
  var grid = [];
  var running = false;
  var timer = null;
  var generation = 0;

  // ===== 模式检测 =====
  var stillLifeTriggered = false;
  var oscillatorTriggered = false;
  var prevStillCellSet = {};   // "r,c" → true，上一次检测到的静物格子
  var prevOscCellSet = {};     // "r,c" → true，上一次检测到的振荡格子

  // ============================================================
  // 辅助函数
  // ============================================================

  /**
   * 检查图案周围是否独立（无相邻活细胞）
   * @param {number[][]} g 网格
   * @param {number} r 锚点行
   * @param {number} c 锚点列
   * @param {number} minDr 检查范围最小行偏移
   * @param {number} maxDr 检查范围最大行偏移
   * @param {number} minDc 检查范围最小列偏移
   * @param {number} maxDc 检查范围最大列偏移
   * @param {number[][]} aliveOffsets 图案活细胞偏移列表 [[dr,dc], ...]
   * @returns {boolean} 图案是否独立
   */
  function isIsolated(g, r, c, minDr, maxDr, minDc, maxDc, aliveOffsets) {
    for (var dr = minDr; dr <= maxDr; dr++) {
      for (var dc = minDc; dc <= maxDc; dc++) {
        var nr = r + dr;
        var nc = c + dc;
        if (nr < 0 || nr >= ROWS || nc < 0 || nc >= COLS) continue;
        var isAliveCell = false;
        for (var i = 0; i < aliveOffsets.length; i++) {
          if (dr === aliveOffsets[i][0] && dc === aliveOffsets[i][1]) {
            isAliveCell = true;
            break;
          }
        }
        if (isAliveCell) continue;
        if (g[nr][nc] === 1) return false;
      }
    }
    return true;
  }

  // ============================================================
  // 网格操作
  // ============================================================

  /** 创建空网格 */
  function createEmptyGrid() {
    var g = [];
    for (var r = 0; r < ROWS; r++) {
      g[r] = [];
      for (var c = 0; c < COLS; c++) {
        g[r][c] = 0;
      }
    }
    return g;
  }

  /** 计算活细胞数量 */
  function countPopulation(g) {
    var count = 0;
    for (var r = 0; r < ROWS; r++) {
      for (var c = 0; c < COLS; c++) {
        count += g[r][c];
      }
    }
    return count;
  }

  /** 计算邻居数（环形边界） */
  function countNeighbors(g, r, c) {
    var count = 0;
    for (var dr = -1; dr <= 1; dr++) {
      for (var dc = -1; dc <= 1; dc++) {
        if (dr === 0 && dc === 0) continue;
        var nr = (r + dr + ROWS) % ROWS;
        var nc = (c + dc + COLS) % COLS;
        count += g[nr][nc];
      }
    }
    return count;
  }

  /** 计算下一代 */
  function nextGeneration(g) {
    var newGrid = createEmptyGrid();
    for (var r = 0; r < ROWS; r++) {
      for (var c = 0; c < COLS; c++) {
        var neighbors = countNeighbors(g, r, c);
        if (g[r][c] === 1) {
          newGrid[r][c] = neighbors === 2 || neighbors === 3 ? 1 : 0;
        } else {
          newGrid[r][c] = neighbors === 3 ? 1 : 0;
        }
      }
    }
    return newGrid;
  }

  // ============================================================
  // 静止图形检测
  // ============================================================

  /**
   * 扫描网格，检测已知的静物图案（含4个旋转变体）。
   * 返回 { count, cells } 供发光动画使用。
   * 检测的静物：
   * - Block (2×2 方块): 1 种朝向，有隔离检查
   * - Tub (水桶/菱形): 1 种朝向，有隔离检查
   * - Boat (船): 4 种朝向，有隔离检查
   * - Beehive (蜂巢): 2 种朝向（水平3×4 + 垂直4×3），有隔离检查
   * - Loaf (面包): 4 种朝向，有隔离检查
   */
  function countStillLifePatterns(g) {
    var count = 0;
    var matchedCells = [];
    var checked = createEmptyGrid();

    // Helper: 标记已检测的格子
    function markAll(cells) {
      for (var i = 0; i < cells.length; i++) {
        var rr = cells[i][0];
        var cc = cells[i][1];
        checked[rr][cc] = 1;
      }
    }

    // =========================================================
    // Block (2×2): 【■■/■■】
    // =========================================================
    for (var r = 0; r < ROWS - 1; r++) {
      for (var c = 0; c < COLS - 1; c++) {
        if (
          g[r][c] === 1 && g[r][c+1] === 1 &&
          g[r+1][c] === 1 && g[r+1][c+1] === 1 &&
          checked[r][c] === 0
        ) {
          var cells = [[r,c],[r,c+1],[r+1,c],[r+1,c+1]];
          if (isIsolated(g, r, c, -1, 2, -1, 2, [[0,0],[0,1],[1,0],[1,1]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }

    // =========================================================
    // Tub (菱形): 5 个细胞
    //   □■□
    //   ■□■
    //   □■□
    // =========================================================
    for (var r = 1; r < ROWS - 1; r++) {
      for (var c = 1; c < COLS - 1; c++) {
        if (
          g[r-1][c] === 1 &&
          g[r][c-1] === 1 && g[r][c] === 0 && g[r][c+1] === 1 &&
          g[r+1][c] === 1 &&
          checked[r-1][c] === 0
        ) {
          var cells = [[r-1,c],[r,c-1],[r,c+1],[r+1,c]];
          if (isIsolated(g, r-1, c-1, 0, 2, 0, 2, [[0,1],[1,0],[1,2],[2,1]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }

    // =========================================================
    // Boat (船): 4 种朝向 (3×3)
    // =========================================================
    // O0: ■■□ / ■□■ / □■□
    for (var r = 0; r < ROWS - 2; r++) {
      for (var c = 0; c < COLS - 2; c++) {
        if (
          g[r][c] === 1 && g[r][c+1] === 1 && g[r][c+2] === 0 &&
          g[r+1][c] === 1 && g[r+1][c+1] === 0 && g[r+1][c+2] === 1 &&
          g[r+2][c] === 0 && g[r+2][c+1] === 1 && g[r+2][c+2] === 0 &&
          checked[r][c] === 0
        ) {
          var cells = [[r,c],[r,c+1],[r+1,c],[r+1,c+2],[r+2,c+1]];
          if (isIsolated(g, r, c, -1, 3, -1, 3, [[0,0],[0,1],[1,0],[1,2],[2,1]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }
    // O1 (90°CW): □■■ / ■□■ / □■□
    for (var r = 0; r < ROWS - 2; r++) {
      for (var c = 0; c < COLS - 2; c++) {
        if (
          g[r][c] === 0 && g[r][c+1] === 1 && g[r][c+2] === 1 &&
          g[r+1][c] === 1 && g[r+1][c+1] === 0 && g[r+1][c+2] === 1 &&
          g[r+2][c] === 0 && g[r+2][c+1] === 1 && g[r+2][c+2] === 0 &&
          checked[r][c+1] === 0
        ) {
          var cells = [[r,c+1],[r,c+2],[r+1,c],[r+1,c+2],[r+2,c+1]];
          if (isIsolated(g, r, c, -1, 3, -1, 3, [[0,1],[0,2],[1,0],[1,2],[2,1]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }
    // O2 (180°): □■□ / ■□■ / □■■
    for (var r = 0; r < ROWS - 2; r++) {
      for (var c = 0; c < COLS - 2; c++) {
        if (
          g[r][c] === 0 && g[r][c+1] === 1 && g[r][c+2] === 0 &&
          g[r+1][c] === 1 && g[r+1][c+1] === 0 && g[r+1][c+2] === 1 &&
          g[r+2][c] === 0 && g[r+2][c+1] === 1 && g[r+2][c+2] === 1 &&
          checked[r][c+1] === 0
        ) {
          var cells = [[r,c+1],[r+1,c],[r+1,c+2],[r+2,c+1],[r+2,c+2]];
          if (isIsolated(g, r, c, -1, 3, -1, 3, [[0,1],[1,0],[1,2],[2,1],[2,2]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }
    // O3 (270°): □■□ / ■□■ / ■■□
    for (var r = 0; r < ROWS - 2; r++) {
      for (var c = 0; c < COLS - 2; c++) {
        if (
          g[r][c] === 0 && g[r][c+1] === 1 && g[r][c+2] === 0 &&
          g[r+1][c] === 1 && g[r+1][c+1] === 0 && g[r+1][c+2] === 1 &&
          g[r+2][c] === 1 && g[r+2][c+1] === 1 && g[r+2][c+2] === 0 &&
          checked[r][c+1] === 0
        ) {
          var cells = [[r,c+1],[r+1,c],[r+1,c+2],[r+2,c],[r+2,c+1]];
          if (isIsolated(g, r, c, -1, 3, -1, 3, [[0,1],[1,0],[1,2],[2,0],[2,1]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }

    // =========================================================
    // Beehive (蜂巢): 2 种朝向
    // =========================================================
    // O0 (3×4): □■■□ / ■□□■ / □■■□
    for (var r = 0; r < ROWS - 2; r++) {
      for (var c = 0; c < COLS - 3; c++) {
        if (
          g[r][c] === 0 && g[r][c+1] === 1 && g[r][c+2] === 1 && g[r][c+3] === 0 &&
          g[r+1][c] === 1 && g[r+1][c+1] === 0 && g[r+1][c+2] === 0 && g[r+1][c+3] === 1 &&
          g[r+2][c] === 0 && g[r+2][c+1] === 1 && g[r+2][c+2] === 1 && g[r+2][c+3] === 0 &&
          checked[r][c+1] === 0
        ) {
          var cells = [[r,c+1],[r,c+2],[r+1,c],[r+1,c+3],[r+2,c+1],[r+2,c+2]];
          if (isIsolated(g, r, c, -1, 3, -1, 4, [[0,1],[0,2],[1,0],[1,3],[2,1],[2,2]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }
    // O1 (4×3): □■□ / ■□■ / ■□■ / □■□
    for (var r = 0; r < ROWS - 3; r++) {
      for (var c = 0; c < COLS - 2; c++) {
        if (
          g[r][c] === 0 && g[r][c+1] === 1 && g[r][c+2] === 0 &&
          g[r+1][c] === 1 && g[r+1][c+1] === 0 && g[r+1][c+2] === 1 &&
          g[r+2][c] === 1 && g[r+2][c+1] === 0 && g[r+2][c+2] === 1 &&
          g[r+3][c] === 0 && g[r+3][c+1] === 1 && g[r+3][c+2] === 0 &&
          checked[r][c+1] === 0
        ) {
          var cells = [[r,c+1],[r+1,c],[r+1,c+2],[r+2,c],[r+2,c+2],[r+3,c+1]];
          if (isIsolated(g, r, c, -1, 4, -1, 3, [[0,1],[1,0],[1,2],[2,0],[2,2],[3,1]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }

    // =========================================================
    // Loaf (面包): 4 种朝向 (4×4)
    // =========================================================
    // O0: □■■□ / ■□□■ / □■□■ / □□■□
    for (var r = 0; r < ROWS - 3; r++) {
      for (var c = 0; c < COLS - 3; c++) {
        if (
          g[r][c] === 0 && g[r][c+1] === 1 && g[r][c+2] === 1 && g[r][c+3] === 0 &&
          g[r+1][c] === 1 && g[r+1][c+1] === 0 && g[r+1][c+2] === 0 && g[r+1][c+3] === 1 &&
          g[r+2][c] === 0 && g[r+2][c+1] === 1 && g[r+2][c+2] === 0 && g[r+2][c+3] === 1 &&
          g[r+3][c] === 0 && g[r+3][c+1] === 0 && g[r+3][c+2] === 1 && g[r+3][c+3] === 0 &&
          checked[r][c+1] === 0
        ) {
          var cells = [[r,c+1],[r,c+2],[r+1,c],[r+1,c+3],[r+2,c+1],[r+2,c+3],[r+3,c+2]];
          if (isIsolated(g, r, c, -1, 4, -1, 4, [[0,1],[0,2],[1,0],[1,3],[2,1],[2,3],[3,2]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }
    // O1 (90°CW): □□■□ / □■□■ / ■□□■ / □■■□
    for (var r = 0; r < ROWS - 3; r++) {
      for (var c = 0; c < COLS - 3; c++) {
        if (
          g[r][c] === 0 && g[r][c+1] === 0 && g[r][c+2] === 1 && g[r][c+3] === 0 &&
          g[r+1][c] === 0 && g[r+1][c+1] === 1 && g[r+1][c+2] === 0 && g[r+1][c+3] === 1 &&
          g[r+2][c] === 1 && g[r+2][c+1] === 0 && g[r+2][c+2] === 0 && g[r+2][c+3] === 1 &&
          g[r+3][c] === 0 && g[r+3][c+1] === 1 && g[r+3][c+2] === 1 && g[r+3][c+3] === 0 &&
          checked[r][c+2] === 0
        ) {
          var cells = [[r,c+2],[r+1,c+1],[r+1,c+3],[r+2,c],[r+2,c+3],[r+3,c+1],[r+3,c+2]];
          if (isIsolated(g, r, c, -1, 4, -1, 4, [[0,2],[1,1],[1,3],[2,0],[2,3],[3,1],[3,2]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }
    // O2 (180°): □■□□ / ■□■□ / ■□□■ / □■■□
    for (var r = 0; r < ROWS - 3; r++) {
      for (var c = 0; c < COLS - 3; c++) {
        if (
          g[r][c] === 0 && g[r][c+1] === 1 && g[r][c+2] === 0 && g[r][c+3] === 0 &&
          g[r+1][c] === 1 && g[r+1][c+1] === 0 && g[r+1][c+2] === 1 && g[r+1][c+3] === 0 &&
          g[r+2][c] === 1 && g[r+2][c+1] === 0 && g[r+2][c+2] === 0 && g[r+2][c+3] === 1 &&
          g[r+3][c] === 0 && g[r+3][c+1] === 1 && g[r+3][c+2] === 1 && g[r+3][c+3] === 0 &&
          checked[r][c+1] === 0
        ) {
          var cells = [[r,c+1],[r+1,c],[r+1,c+2],[r+2,c],[r+2,c+3],[r+3,c+1],[r+3,c+2]];
          if (isIsolated(g, r, c, -1, 4, -1, 4, [[0,1],[1,0],[1,2],[2,0],[2,3],[3,1],[3,2]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }
    // O3 (270°): □■■□ / ■□□■ / ■□■□ / □■□□
    for (var r = 0; r < ROWS - 3; r++) {
      for (var c = 0; c < COLS - 3; c++) {
        if (
          g[r][c] === 0 && g[r][c+1] === 1 && g[r][c+2] === 1 && g[r][c+3] === 0 &&
          g[r+1][c] === 1 && g[r+1][c+1] === 0 && g[r+1][c+2] === 0 && g[r+1][c+3] === 1 &&
          g[r+2][c] === 1 && g[r+2][c+1] === 0 && g[r+2][c+2] === 1 && g[r+2][c+3] === 0 &&
          g[r+3][c] === 0 && g[r+3][c+1] === 1 && g[r+3][c+2] === 0 && g[r+3][c+3] === 0 &&
          checked[r][c+1] === 0
        ) {
          var cells = [[r,c+1],[r,c+2],[r+1,c],[r+1,c+3],[r+2,c],[r+2,c+2],[r+3,c+1]];
          if (isIsolated(g, r, c, -1, 4, -1, 4, [[0,1],[0,2],[1,0],[1,3],[2,0],[2,2],[3,1]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }

    return { count: count, cells: matchedCells };
  }

  /**
   * 扫描网格，通过模板匹配检测已知的震荡器图案。
   * 返回 { count, cells } 供发光动画使用。
   * 检测的震荡器：
   * - Blinker (闪烁器): 水平/垂直两种相位，有隔离检查
   * - Toad (蟾蜍): 两种相位，有隔离检查
   * - Beacon (信标灯): 两种相位 (4×4)，有隔离检查
   */
  function countOscillatorPatterns(g) {
    var count = 0;
    var matchedCells = [];
    var checked = createEmptyGrid();

    function markAll(cells) {
      for (var i = 0; i < cells.length; i++) {
        checked[cells[i][0]][cells[i][1]] = 1;
      }
    }

    // =========================================================
    // Blinker (闪烁器): 周期 2 振荡器
    // =========================================================
    // 相位 A: 水平 ■■■
    for (var r = 0; r < ROWS; r++) {
      for (var c = 0; c < COLS - 2; c++) {
        if (
          g[r][c] === 1 && g[r][c+1] === 1 && g[r][c+2] === 1 &&
          checked[r][c] === 0
        ) {
          var cells = [[r,c],[r,c+1],[r,c+2]];
          if (isIsolated(g, r, c, -1, 1, -1, 3, [[0,0],[0,1],[0,2]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }
    // 相位 B: 垂直 ■ / ■ / ■
    for (var r = 0; r < ROWS - 2; r++) {
      for (var c = 0; c < COLS; c++) {
        if (
          g[r][c] === 1 && g[r+1][c] === 1 && g[r+2][c] === 1 &&
          checked[r][c] === 0
        ) {
          var cells = [[r,c],[r+1,c],[r+2,c]];
          if (isIsolated(g, r, c, -1, 3, -1, 1, [[0,0],[1,0],[2,0]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }

    // =========================================================
    // Toad (蟾蜍): 周期 2 振荡器, 2×4 区域
    // =========================================================
    // 相位 A: ■■■□ / □□■■
    for (var r = 0; r < ROWS - 1; r++) {
      for (var c = 0; c < COLS - 3; c++) {
        if (
          g[r][c] === 1 && g[r][c+1] === 1 && g[r][c+2] === 1 && g[r][c+3] === 0 &&
          g[r+1][c] === 0 && g[r+1][c+1] === 0 && g[r+1][c+2] === 1 && g[r+1][c+3] === 1 &&
          checked[r][c] === 0
        ) {
          var cells = [[r,c],[r,c+1],[r,c+2],[r+1,c+2],[r+1,c+3]];
          if (isIsolated(g, r, c, -1, 2, -1, 4, [[0,0],[0,1],[0,2],[1,2],[1,3]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }
    // 相位 B: □■■□ / ■□□■
    for (var r = 0; r < ROWS - 1; r++) {
      for (var c = 0; c < COLS - 3; c++) {
        if (
          g[r][c] === 0 && g[r][c+1] === 1 && g[r][c+2] === 1 && g[r][c+3] === 0 &&
          g[r+1][c] === 1 && g[r+1][c+1] === 0 && g[r+1][c+2] === 0 && g[r+1][c+3] === 1 &&
          checked[r][c+1] === 0
        ) {
          var cells = [[r,c+1],[r,c+2],[r+1,c],[r+1,c+3]];
          if (isIsolated(g, r, c, -1, 2, -1, 4, [[0,1],[0,2],[1,0],[1,3]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }

    // =========================================================
    // Beacon (信标灯): 周期 2 振荡器, 4×4 区域, 两个相向方块组成
    // =========================================================
    // 相位 A: ■■□□ / ■■□□ / □□■■ / □□■■
    for (var r = 0; r < ROWS - 3; r++) {
      for (var c = 0; c < COLS - 3; c++) {
        if (
          g[r][c] === 1 && g[r][c+1] === 1 && g[r][c+2] === 0 && g[r][c+3] === 0 &&
          g[r+1][c] === 1 && g[r+1][c+1] === 1 && g[r+1][c+2] === 0 && g[r+1][c+3] === 0 &&
          g[r+2][c] === 0 && g[r+2][c+1] === 0 && g[r+2][c+2] === 1 && g[r+2][c+3] === 1 &&
          g[r+3][c] === 0 && g[r+3][c+1] === 0 && g[r+3][c+2] === 1 && g[r+3][c+3] === 1 &&
          checked[r][c] === 0
        ) {
          var cells = [[r,c],[r,c+1],[r+1,c],[r+1,c+1],[r+2,c+2],[r+2,c+3],[r+3,c+2],[r+3,c+3]];
          if (isIsolated(g, r, c, -1, 4, -1, 4, [[0,0],[0,1],[1,0],[1,1],[2,2],[2,3],[3,2],[3,3]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }
    // 相位 B: ■■□□ / ■□■□ / □■□■ / □□■■
    for (var r = 0; r < ROWS - 3; r++) {
      for (var c = 0; c < COLS - 3; c++) {
        if (
          g[r][c] === 1 && g[r][c+1] === 1 && g[r][c+2] === 0 && g[r][c+3] === 0 &&
          g[r+1][c] === 1 && g[r+1][c+1] === 0 && g[r+1][c+2] === 1 && g[r+1][c+3] === 0 &&
          g[r+2][c] === 0 && g[r+2][c+1] === 1 && g[r+2][c+2] === 0 && g[r+2][c+3] === 1 &&
          g[r+3][c] === 0 && g[r+3][c+1] === 0 && g[r+3][c+2] === 1 && g[r+3][c+3] === 1 &&
          checked[r][c] === 0
        ) {
          var cells = [[r,c],[r,c+1],[r+1,c],[r+1,c+2],[r+2,c+1],[r+2,c+3],[r+3,c+2],[r+3,c+3]];
          if (isIsolated(g, r, c, -1, 4, -1, 4, [[0,0],[0,1],[1,0],[1,2],[2,1],[2,3],[3,2],[3,3]])) {
            count++;
            matchedCells = matchedCells.concat(cells);
            markAll(cells);
          }
        }
      }
    }

    return { count: count, cells: matchedCells };
  }

  // ============================================================
  // 模式检测与传送门触发
  // ============================================================

  /** 对指定格子执行发光动画 */
  function flashCells(cellList, cellSet) {
    for (var i = 0; i < cellList.length; i++) {
      var r = cellList[i][0];
      var c = cellList[i][1];
      var key = r + "," + c;
      // 只对新匹配到的格子发光（已在集合中的跳过）
      if (cellSet[key]) continue;
      cellSet[key] = true;
      var index = r * COLS + c;
      var cell = gridEl.children[index];
      if (cell) {
        cell.classList.add("pattern-glow");
        // 动画结束后移除 class
        (function (el) {
          setTimeout(function () { el.classList.remove("pattern-glow"); }, 620);
        })(cell);
      }
    }
  }

  function checkPatternsAndPortals() {
    // 每 3 代扫描一次以减少性能开销
    if (generation % 3 === 0) {

      // --- 静止图形检测 ---
      if (!stillLifeTriggered) {
        var stillResult = countStillLifePatterns(grid);
        flashCells(stillResult.cells, prevStillCellSet);
        if (stillResult.count >= 5) {
          stillLifeTriggered = true;
          setTimeout(function () {
            revealPortal(portalsStill);
          }, 500);
        }
      }

      // --- 震荡图形检测 ---
      if (!oscillatorTriggered) {
        var oscResult = countOscillatorPatterns(grid);
        flashCells(oscResult.cells, prevOscCellSet);
        if (oscResult.count >= 5) {
          oscillatorTriggered = true;
          setTimeout(function () {
            revealPortal(portalsOsc);
          }, 500);
        }
      }
    }
  }

  // ============================================================
  // 渲染
  // ============================================================

  /** 创建网格 DOM */
  function renderGrid() {
    if (!gridEl) return;
    gridEl.innerHTML = "";
    gridEl.style.gridTemplateColumns = "repeat(" + COLS + ", 1fr)";
    gridEl.style.gridTemplateRows = "repeat(" + ROWS + ", 1fr)";

    for (var r = 0; r < ROWS; r++) {
      for (var c = 0; c < COLS; c++) {
        var cell = document.createElement("button");
        cell.className = "conway-cell" + (grid[r][c] === 1 ? " alive" : "");
        cell.dataset.row = String(r);
        cell.dataset.col = String(c);
        cell.setAttribute("aria-label", "格子 " + (r + 1) + "-" + (c + 1));
        cell.addEventListener("click", handleCellClick);
        if (r === 0 || r === ROWS - 1 || c === 0 || c === COLS - 1) {
          cell.addEventListener("mouseenter", handleCellDrag);
        }
        gridEl.appendChild(cell);
      }
    }
  }

  /** 点击/触控放置生命 */
  var isDragging = false;

  function handleCellClick(e) {
    if (running) return;
    var cell = e.currentTarget;
    var r = parseInt(cell.dataset.row, 10);
    var c = parseInt(cell.dataset.col, 10);
    toggleCellState(r, c);
  }

  function handleCellDrag(e) {
    if (!isDragging || running) return;
    var cell = e.currentTarget;
    var r = parseInt(cell.dataset.row, 10);
    var c = parseInt(cell.dataset.col, 10);
    grid[r][c] = 1;
    cell.className = "conway-cell alive";
  }

  /** 切换单个格子状态 */
  function toggleCellState(r, c) {
    grid[r][c] = grid[r][c] === 1 ? 0 : 1;
    var index = r * COLS + c;
    var cell = gridEl.children[index];
    if (cell) {
      cell.className = "conway-cell" + (grid[r][c] === 1 ? " alive" : "");
    }
  }

  /** 更新所有格子 */
  function updateGridDisplay() {
    if (!gridEl) return;
    for (var r = 0; r < ROWS; r++) {
      for (var c = 0; c < COLS; c++) {
        var index = r * COLS + c;
        var cell = gridEl.children[index];
        if (cell) {
          cell.className = "conway-cell" + (grid[r][c] === 1 ? " alive" : "");
        }
      }
    }
  }

  // ============================================================
  // 传送门显现动画
  // ============================================================

  function revealPortal(portalEl) {
    if (!portalEl) return;
    portalEl.style.display = "block";
    portalEl.classList.add("revealing");
    setTimeout(function () {
      portalEl.classList.remove("revealing");
    }, 800);
  }

  // ============================================================
  // 游戏循环
  // ============================================================

  function gameTick() {
    grid = nextGeneration(grid);
    generation++;
    updateGridDisplay();
    checkPatternsAndPortals();

    // 如果生命全部消失，自动暂停
    if (countPopulation(grid) === 0 && running) {
      pauseGame();
    }
  }

  function startGame() {
    if (running) return;
    // 检查是否有活细胞
    if (countPopulation(grid) === 0) return;
    running = true;
    if (startBtn) startBtn.disabled = true;
    if (pauseBtn) pauseBtn.disabled = false;
    timer = setInterval(gameTick, INTERVAL_MS);
  }

  function pauseGame() {
    running = false;
    if (timer) {
      clearInterval(timer);
      timer = null;
    }
    if (startBtn) startBtn.disabled = false;
    if (pauseBtn) pauseBtn.disabled = true;
  }

  function resetGame() {
    pauseGame();
    generation = 0;
    stillLifeTriggered = false;
    oscillatorTriggered = false;
    prevStillCellSet = {};
    prevOscCellSet = {};

    grid = createEmptyGrid();

    // 重置传送门
    if (portalsStill) {
      portalsStill.style.display = "none";
    }
    if (portalsOsc) {
      portalsOsc.style.display = "none";
    }

    renderGrid();
  }

  // ============================================================
  // 鼠标拖拽绘制支持
  // ============================================================

  function initDragDrawing() {
    if (!gridEl) return;

    gridEl.addEventListener("mousedown", function (e) {
      if (running) return;
      isDragging = true;
      var cell = e.target;
      if (cell.classList && cell.classList.contains("conway-cell")) {
        var r = parseInt(cell.dataset.row, 10);
        var c = parseInt(cell.dataset.col, 10);
        grid[r][c] = 1;
        cell.className = "conway-cell alive";
      }
    });

    document.addEventListener("mousemove", function (e) {
      if (!isDragging || running) return;
      var el = document.elementFromPoint(e.clientX, e.clientY);
      if (el && el.classList && el.classList.contains("conway-cell")) {
        var r = parseInt(el.dataset.row, 10);
        var c = parseInt(el.dataset.col, 10);
        if (grid[r][c] === 0) {
          grid[r][c] = 1;
          el.className = "conway-cell alive";
        }
      }
    });

    document.addEventListener("mouseup", function () {
      isDragging = false;
    });

    // 触控支持
    gridEl.addEventListener("touchstart", function (e) {
      if (running) return;
      var touch = e.touches[0];
      var el = document.elementFromPoint(touch.clientX, touch.clientY);
      if (el && el.classList && el.classList.contains("conway-cell")) {
        var r = parseInt(el.dataset.row, 10);
        var c = parseInt(el.dataset.col, 10);
        toggleCellState(r, c);
      }
    }, { passive: true });
  }

  // ============================================================
  // 初始化
  // ============================================================

  function init() {
    grid = createEmptyGrid();
    renderGrid();
    initDragDrawing();

    if (resetBtn) resetBtn.addEventListener("click", resetGame);
    if (startBtn) startBtn.addEventListener("click", startGame);
    if (pauseBtn) pauseBtn.addEventListener("click", pauseGame);
  }

  init();
})();
</script>
