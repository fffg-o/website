---
// ============================================================
// 符文之门 —— 文字输入谜题房间
// ============================================================
import Layout from '../../../layouts/Layout.astro';
import MazeMap from '../../../components/MazeMap.astro';
import PuzzleRoom from '../../../components/PuzzleRoom.astro';
import type { RoomExport } from '../../../data/maze';

/** 迷宫基础设施读取的导出数据 */
export const room: RoomExport = {
  id: 'lockpick',
  title: '符文之门',
  description: '一扇刻满古老符文的石门挡在面前。',
  date: '2026-05-12',
  tags: ['迷宫', '密码'],
  portalSlots: [
    { label: '石门缓缓打开，露出一个宝库入口', description: '里面金光闪闪' },
    { label: '旁边出现了一条黑暗的通道', description: '通道深处传来奇怪的回声' },
  ],
};

interface Props {
  room: RoomExport;
  baseUrl: string;
  portals: import('../../../data/maze').Portal[];
}
const { room: meta, baseUrl, portals: externalPortals } = Astro.props;
---

<Layout title={`${meta.title} - 迷宫 - fffg`} description={meta.description} hideScrollButtons={true}>
  <MazeMap currentRoomId={meta.id} />
  <div class="blog-page">
    <article class="blog-article prose prose-zinc dark:prose-invert">
      <header class="mb-6 not-prose sm:mb-8">
        <h1 class="mb-3 text-2xl font-bold text-text sm:text-3xl">{meta.title}</h1>
        <div class="flex flex-wrap items-center gap-3">
          <time class="text-sm text-text-muted">{meta.date}</time>
          <span class="text-text-muted">·</span>
          <span class="inline-flex items-center gap-1 rounded-md bg-accent/10 px-2 py-0.5 text-xs text-accent">
            <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            路由已加密
          </span>
        </div>
        {meta.tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {meta.tags.map((tag: string) => (
              <span class="rounded-full border border-border bg-card px-2.5 py-0.5 text-xs text-text-muted">#{tag}</span>
            ))}
          </div>
        )}
      </header>

      <PuzzleRoom room={meta} baseUrl={baseUrl} portals={externalPortals}>
        <div class="puzzle-area" id="puzzle-area">
          <div class="puzzle-atmosphere">
            <p>石门上的符文缓缓流动，似乎在等待某种开启的咒语……</p>
          </div>
          <div class="puzzle-header">
            <h2 class="puzzle-title">🧩 谜题</h2>
            <span class="puzzle-attempts" id="puzzle-attempts">剩余尝试: <span id="attempts-count">3</span></span>
          </div>
          <p class="puzzle-prompt">石门上的符文拼出了一个古老的词汇。请输入你看到的词语：</p>
          <div class="puzzle-input-group">
            <input
              type="text"
              class="puzzle-input"
              id="answer-input"
              placeholder="输入开启之词..."
              autocomplete="off"
              spellcheck="false"
            />
            <button class="puzzle-btn puzzle-btn-primary" id="submit-btn">确认</button>
            <p class="puzzle-hint" id="hint" style="display:none">💡 符文的意思是"照亮"。</p>
          </div>
        </div>
      </PuzzleRoom>
    </article>
    <aside class="blog-toc-sidebar"></aside>
  </div>
</Layout>

<script>
  (function () {
    var answer = '1';
    var maxAttempts = 3;
    var attempts = 0;
    var input = document.getElementById('answer-input');
    var btn = document.getElementById('submit-btn');
    var countEl = document.getElementById('attempts-count');
    var hintEl = document.getElementById('hint');
    var area = document.getElementById('puzzle-area');

    function checkAnswer() {
      if (!input) return;
      var val = input.value.trim();
      if (!val) return;
      attempts++;
      if (countEl) countEl.textContent = String(Math.max(0, maxAttempts - attempts));
      if (val.toLowerCase() === answer.toLowerCase()) {
        if (area) { area.style.opacity = '0'; area.style.transform = 'translateY(-20px)'; area.style.transition = 'all 0.5s ease'; setTimeout(function () { area.style.display = 'none'; }, 500); }
        if (window.fireConfetti) window.fireConfetti();
        setTimeout(function () { if (window.showPortals) window.showPortals(); }, 600);
      } else {
        if (hintEl) hintEl.style.display = 'block';
        if (attempts >= maxAttempts) {
          if (input) input.disabled = true;
          if (btn) btn.disabled = true;
        } else {
          input.classList.add('puzzle-input-error');
          setTimeout(function () { input.classList.remove('puzzle-input-error'); }, 500);
          input.value = '';
          input.focus();
        }
      }
    }

    if (btn) btn.addEventListener('click', checkAnswer);
    if (input) {
      input.addEventListener('keydown', function (e) { if (e.key === 'Enter') checkAnswer(); });
      input.focus();
    }
  })();
</script>

<style>
  .puzzle-atmosphere {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding: 1rem 1.25rem;
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    border-radius: 1rem;
  }
  .puzzle-atmosphere p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }
  .puzzle-attempts {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    background: color-mix(in srgb, var(--color-border) 50%, transparent);
    padding: 0.25rem 0.625rem;
    border-radius: 0.5rem;
  }
  .puzzle-input-group {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
</style>
