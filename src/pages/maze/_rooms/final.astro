---
// ============================================================
// 勇者试炼 —— 选择题谜题房间
// ============================================================
import Layout from '../../../layouts/Layout.astro';
import MazeMap from '../../../components/MazeMap.astro';
import PuzzleRoom from '../../../components/PuzzleRoom.astro';
import type { RoomExport } from '../../../data/maze';

/** 迷宫基础设施读取的导出数据 */
export const room: RoomExport = {
  id: 'final',
  title: '勇者试炼',
  description: '最终的试炼，选择你的命运。',
  date: '2026-05-12',
  tags: ['迷宫', '终章'],
  portals: [
    { label: '🔁 回到起点重新开始', description: '迷宫循环往复……', targetId: 'welcome' },
    { label: '一扇隐藏的秘门', description: '似乎通向未知领域', targetId: 'lockpick' },
  ],
};

interface Props {
  room: RoomExport;
  baseUrl: string;
}
const { room: meta, baseUrl } = Astro.props;
---

<Layout title={`${meta.title} - 迷宫 - fffg`} description={meta.description}>
  <MazeMap currentRoomId={meta.id} />
  <div class="blog-page">
    <article class="blog-article prose prose-zinc dark:prose-invert">
      <header class="mb-6 not-prose sm:mb-8">
        <h1 class="mb-3 text-2xl font-bold text-text sm:text-3xl">{meta.title}</h1>
        <div class="flex flex-wrap items-center gap-3">
          <time class="text-sm text-text-muted">{meta.date}</time>
          <span class="text-text-muted">·</span>
          <span class="inline-flex items-center gap-1 rounded-md bg-accent/10 px-2 py-0.5 text-xs text-accent">
            <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            路由已加密
          </span>
        </div>
        {meta.tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {meta.tags.map((tag: string) => (
              <span class="rounded-full border border-border bg-card px-2.5 py-0.5 text-xs text-text-muted">#{tag}</span>
            ))}
          </div>
        )}
      </header>

      <PuzzleRoom room={meta} baseUrl={baseUrl}>
        <div class="puzzle-area" id="puzzle-area">
          <div class="puzzle-atmosphere">
            <p>金色大门在身后缓缓关闭。前方有三个不同的出口，但只有一个通向自由……</p>
          </div>
          <div class="puzzle-header">
            <h2 class="puzzle-title">🧩 谜题</h2>
          </div>
          <p class="puzzle-prompt">哪条路才是真正的出口？</p>
          <div class="puzzle-choices">
            <button class="puzzle-choice-btn" data-option-id="a">
              <span class="puzzle-choice-marker">A</span>
              <span class="puzzle-choice-label">左边的门——门上刻着"力量"</span>
            </button>
            <button class="puzzle-choice-btn" data-option-id="b">
              <span class="puzzle-choice-marker">B</span>
              <span class="puzzle-choice-label">中间的门——门上刻着"智慧"</span>
            </button>
            <button class="puzzle-choice-btn" data-option-id="c">
              <span class="puzzle-choice-marker">C</span>
              <span class="puzzle-choice-label">右边的门——门上刻着"勇气"</span>
            </button>
          </div>
          <p class="puzzle-hint" id="hint" style="display:none">💡 回想这一路的经历……真正的力量来自于智慧。</p>
        </div>
      </PuzzleRoom>
    </article>
    <aside class="blog-toc-sidebar"></aside>
  </div>
</Layout>

<script>
  (function () {
    var correctId = 'b';
    var options = document.querySelectorAll('.puzzle-choice-btn');
    var hintEl = document.getElementById('hint');
    var area = document.getElementById('puzzle-area');

    options.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var optionId = btn.getAttribute('data-option-id') || '';
        if (optionId === correctId) {
          options.forEach(function (b) { b.classList.remove('puzzle-choice-selected'); });
          btn.classList.add('puzzle-choice-correct');
          setTimeout(function () {
            if (area) { area.style.opacity = '0'; area.style.transform = 'translateY(-20px)'; area.style.transition = 'all 0.5s ease'; setTimeout(function () { area.style.display = 'none'; }, 500); }
            if (window.fireConfetti) window.fireConfetti();
            setTimeout(function () { if (window.showPortals) window.showPortals(); }, 600);
          }, 500);
        } else {
          btn.classList.add('puzzle-choice-wrong');
          if (hintEl) hintEl.style.display = 'block';
          setTimeout(function () { btn.classList.remove('puzzle-choice-wrong'); }, 600);
        }
      });
    });
  })();
</script>

<style>
  .puzzle-atmosphere {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding: 1rem 1.25rem;
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    border-radius: 1rem;
  }
  .puzzle-atmosphere p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }
  .puzzle-choices {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .puzzle-choice-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 0.875rem 1rem;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
    text-align: left;
    font-size: 0.9375rem;
    color: var(--color-text);
  }
  .puzzle-choice-btn:hover {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 5%, transparent);
  }
  .puzzle-choice-marker {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    font-weight: 700;
    font-size: 0.875rem;
    flex-shrink: 0;
  }
  .puzzle-choice-correct {
    border-color: #22c55e !important;
    background: color-mix(in srgb, #22c55e 10%, transparent) !important;
  }
  .puzzle-choice-correct .puzzle-choice-marker { background: #22c55e; color: white; border-color: #22c55e; }
  .puzzle-choice-wrong { animation: shake 0.4s ease; border-color: #ef4444 !important; }
  .puzzle-choice-wrong .puzzle-choice-marker { border-color: #ef4444; color: #ef4444; }
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    50% { transform: translateX(6px); }
    75% { transform: translateX(-4px); }
  }
</style>
