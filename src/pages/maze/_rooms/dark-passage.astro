---
// ============================================================
// 黑暗通道 —— 顺序操作谜题房间
// ============================================================
import MazeMap from '../../../components/MazeMap.astro';
import type { RoomExport } from '../../../data/maze';
import type { Portal } from '../../../data/maze';
import { getMazeUrl } from '../../../lib/maze-url';

// 页面元数据（局部常量，不导出）
const title = '黑暗通道';
const description = '黑暗中摸索，火把是唯一的光源。';
const date = '2026-05-12';
const tags = ['迷宫', '顺序'];

/** 迷宫基础设施读取的导出数据 */
export const room: RoomExport = {
  id: 'dark-passage',
  portalSlots: [
    { label: '通道尽头出现了一扇金色大门', description: '门上刻着"勇者"二字' },
    { label: '墙上的裂缝透出微光', description: '似乎通向另一个房间' },
  ],
};

interface Props {
  room: RoomExport;
  baseUrl: string;
  portals: Portal[];
}
const { room: meta, baseUrl, portals: externalPortals } = Astro.props;

function portalHref(targetId: string): string {
  return `${baseUrl}${getMazeUrl(targetId)}?from=${meta.id}`;
}
---

<MazeMap currentRoomId={meta.id} />
<div class="blog-page">
  <article class="blog-article prose prose-zinc dark:prose-invert">
    <header class="mb-6 not-prose sm:mb-8">
      <h1 class="mb-3 text-2xl font-bold text-text sm:text-3xl">{title}</h1>
      <div class="flex flex-wrap items-center gap-3">
        <time class="text-sm text-text-muted">{date}</time>
        <span class="text-text-muted">·</span>
        <span class="inline-flex items-center gap-1 rounded-md bg-accent/10 px-2 py-0.5 text-xs text-accent">
          <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          路由已加密
        </span>
      </div>
      {tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {tags.map((tag: string) => (
            <span class="rounded-full border border-border bg-card px-2.5 py-0.5 text-xs text-text-muted">#{tag}</span>
          ))}
        </div>
      )}
    </header>

    <div class="puzzle-room" data-puzzle-id={meta.id}>
      <div class="puzzle-area" id="puzzle-area">
        <div class="puzzle-atmosphere">
          <p>通道两侧每隔十步就有一支熄灭的火把。你需要在正确的顺序下点燃它们……</p>
        </div>
        <div class="puzzle-header">
          <h2 class="puzzle-title">🧩 谜题</h2>
        </div>
        <p class="puzzle-prompt">按照正确的顺序点击火把（从外到内）：</p>
        <p class="puzzle-sequence-instruction">已选择: <span id="selected-count">0</span> / 3</p>
        <div class="puzzle-sequence-items">
          <button class="puzzle-item-btn puzzle-sequence-btn" data-item-id="torch-1" data-order="-1">
            <span class="puzzle-item-icon">🔥</span>
            <span class="puzzle-item-label">第一支火把</span>
            <span class="puzzle-sequence-order" style="display:none"></span>
          </button>
          <button class="puzzle-item-btn puzzle-sequence-btn" data-item-id="torch-2" data-order="-1">
            <span class="puzzle-item-icon">🔥</span>
            <span class="puzzle-item-label">第二支火把</span>
            <span class="puzzle-sequence-order" style="display:none"></span>
          </button>
          <button class="puzzle-item-btn puzzle-sequence-btn" data-item-id="torch-3" data-order="-1">
            <span class="puzzle-item-icon">🔥</span>
            <span class="puzzle-item-label">第三支火把</span>
            <span class="puzzle-sequence-order" style="display:none"></span>
          </button>
        </div>
        <div class="puzzle-items-actions">
          <button class="puzzle-btn puzzle-btn-secondary" id="reset-btn">重置</button>
          <button class="puzzle-btn puzzle-btn-primary" id="check-btn">确认顺序</button>
          <p class="puzzle-hint" id="hint" style="display:none">💡 最深的黑暗从最深处开始驱散。</p>
        </div>
      </div>

      <!-- 跳转链接（解谜成功后显示） -->
      <div class="room-portals" id="room-portals" style="display:none">
        <div class="room-portals-glow"></div>
        <div class="room-portals-content">
          <h3 class="room-portals-title">🚪 可前往</h3>
          <div class="room-portals-list">
            {externalPortals.map((portal: Portal) => (
              <a href={portalHref(portal.targetId)} class="room-portal-link">
                <span class="room-portal-icon">🚪</span>
                <span class="room-portal-info">
                  <span class="room-portal-label">{portal.label}</span>
                  {portal.description && <span class="room-portal-desc">{portal.description}</span>}
                </span>
                <span class="room-portal-arrow">→</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </article>
  <aside class="blog-toc-sidebar"></aside>
</div>

<script>
  (function () {
    function fireConfetti() {
      var colors = ['#ff6b6b', '#feca57', '#48dbfb', '#ff9ff3', '#54a0ff', '#5f27cd'];
      for (var i = 0; i < 40; i++) {
        var piece = document.createElement('div');
        piece.className = 'confetti-piece';
        piece.style.left = Math.random() * 100 + 'vw';
        piece.style.background = colors[Math.floor(Math.random() * colors.length)];
        piece.style.width = (Math.random() * 8 + 4) + 'px';
        piece.style.height = (Math.random() * 8 + 4) + 'px';
        piece.style.animationDuration = (Math.random() * 2 + 1.5) + 's';
        piece.style.animationDelay = (Math.random() * 0.5) + 's';
        document.body.appendChild(piece);
        setTimeout(function () { piece.remove(); }, 3000);
      }
    }

    var correctOrder = ['torch-3', 'torch-1', 'torch-2'];
    var items = document.querySelectorAll('.puzzle-sequence-btn');
    var countEl = document.getElementById('selected-count');
    var resetBtn = document.getElementById('reset-btn');
    var checkBtn = document.getElementById('check-btn');
    var hintEl = document.getElementById('hint');
    var area = document.getElementById('puzzle-area');
    var seqOrder = [];

    function updateUI() {
      if (countEl) countEl.textContent = String(seqOrder.length);
      items.forEach(function (btn) {
        var id = btn.getAttribute('data-item-id') || '';
        var idx = seqOrder.indexOf(id);
        var orderSpan = btn.querySelector('.puzzle-sequence-order');
        if (idx !== -1) {
          btn.setAttribute('data-order', String(idx + 1));
          btn.classList.add('puzzle-item-selected');
          if (orderSpan) { orderSpan.textContent = String(idx + 1); orderSpan.style.display = 'flex'; }
        } else {
          btn.setAttribute('data-order', '-1');
          btn.classList.remove('puzzle-item-selected');
          if (orderSpan) orderSpan.style.display = 'none';
        }
      });
    }

    function resetSeq() { seqOrder = []; updateUI(); }

    items.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var id = btn.getAttribute('data-item-id') || '';
        var idx = seqOrder.indexOf(id);
        if (idx !== -1) {
          seqOrder = seqOrder.slice(0, idx);
        } else {
          seqOrder.push(id);
        }
        updateUI();
      });
    });

    if (resetBtn) resetBtn.addEventListener('click', resetSeq);
    if (checkBtn) {
      checkBtn.addEventListener('click', function () {
        var ok = seqOrder.length === correctOrder.length &&
          seqOrder.every(function (id, i) { return id === correctOrder[i]; });
        if (ok) {
          if (area) { area.style.opacity = '0'; area.style.transform = 'translateY(-20px)'; area.style.transition = 'all 0.5s ease'; setTimeout(function () { area.style.display = 'none'; }, 500); }
          fireConfetti();
          setTimeout(function () {
            var portals = document.getElementById('room-portals');
            if (portals) { portals.style.display = 'block'; setTimeout(function () { portals.classList.add('room-portals-visible'); }, 50); }
          }, 600);
        } else {
          if (hintEl) hintEl.style.display = 'block';
          resetSeq();
        }
      });
    }
  })();
</script>

<style>
  .puzzle-room {
    max-width: 600px;
    margin: 0 auto;
    padding: 1.5rem 0;
  }

  /* ===== 通用谜题样式 ===== */
  .puzzle-area {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
    transition: all 0.5s ease;
  }

  .puzzle-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .puzzle-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .puzzle-prompt {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .puzzle-hint {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: #f59e0b;
    animation: fade-in 0.3s ease-out;
  }

  .puzzle-btn {
    padding: 0.625rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    border: none;
    border-radius: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
    align-self: flex-start;
  }

  .puzzle-btn-primary { background: var(--color-primary); color: white; }
  .puzzle-btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .puzzle-btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .puzzle-btn-secondary { background: color-mix(in srgb, var(--color-border) 50%, transparent); color: var(--color-text); }
  .puzzle-btn-secondary:hover { background: var(--color-border); }

  .puzzle-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    border: 2px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-surface);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }

  .puzzle-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .puzzle-input-error { animation: shake 0.4s ease; border-color: #ef4444 !important; }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    50% { transform: translateX(6px); }
    75% { transform: translateX(-4px); }
  }

  .puzzle-success-icon {
    font-size: 3rem;
    margin-bottom: 0.75rem;
    animation: success-bounce 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes success-bounce {
    0% { transform: scale(0) rotate(-30deg); }
    60% { transform: scale(1.2) rotate(5deg); }
    100% { transform: scale(1) rotate(0deg); }
  }

  .puzzle-success-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .puzzle-success-text {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .puzzle-item-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 0.875rem 1rem;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
    text-align: left;
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  .puzzle-item-btn:hover {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 5%, transparent);
  }

  .puzzle-item-btn.puzzle-item-selected {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 30%, transparent);
  }

  .puzzle-item-icon {
    font-size: 1.5rem;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-card);
    border-radius: 0.625rem;
    flex-shrink: 0;
  }

  .puzzle-item-label { font-weight: 500; }

  @media (max-width: 639px) {
    .puzzle-room { padding: 1rem 0; }
    .puzzle-area { padding: 1.25rem; border-radius: 0.75rem; }
  }

  /* ===== 房间专属样式 ===== */
  .puzzle-atmosphere {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding: 1rem 1.25rem;
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    border-radius: 1rem;
  }
  .puzzle-atmosphere p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }
  .puzzle-sequence-instruction {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
  .puzzle-sequence-items {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .puzzle-sequence-btn { position: relative; }
  .puzzle-sequence-order {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    width: 1.75rem;
    height: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: white;
    font-size: 0.8125rem;
    font-weight: 700;
    border-radius: 50%;
  }
  .puzzle-items-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  /* ===== 跳转链接 ===== */
  .room-portals {
    display: none;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    margin-top: 2rem;
  }
  .room-portals-visible { opacity: 1; transform: translateY(0); }
  .room-portals-glow {
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent), #22c55e, var(--color-primary));
    background-size: 300% 100%;
    border-radius: 2px;
    margin-bottom: 1.5rem;
    animation: shimmer 2s linear infinite;
  }
  @keyframes shimmer {
    0% { background-position: 0% 0; }
    100% { background-position: 300% 0; }
  }
  .room-portals-content {
    text-align: center;
    padding: 2rem 1.5rem;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
  }
  .room-portals-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }
  .room-portals-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .room-portal-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.2s;
  }
  .room-portal-link:hover {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border-color: var(--color-accent);
    transform: translateX(4px);
  }
  .room-portal-icon { font-size: 1.5rem; flex-shrink: 0; }
  .room-portal-info { display: flex; flex-direction: column; gap: 0.125rem; flex: 1; min-width: 0; }
  .room-portal-label { font-size: 1rem; font-weight: 600; color: var(--color-text); }
  .room-portal-desc { font-size: 0.8125rem; color: var(--color-text-muted); }
  .room-portal-arrow { font-size: 1.25rem; color: var(--color-accent); flex-shrink: 0; transition: transform 0.2s; }
  .room-portal-link:hover .room-portal-arrow { transform: translateX(4px); }
</style>
