---
// ============================================================
// 宝藏密室 —— 点击物品谜题房间
// ============================================================
import Layout from '../../../layouts/Layout.astro';
import MazeMap from '../../../components/MazeMap.astro';
import PuzzleRoom from '../../../components/PuzzleRoom.astro';
import type { RoomExport } from '../../../data/maze';
import type { Portal } from '../../../data/maze';

/** 迷宫基础设施读取的导出数据 */
export const room: RoomExport = {
  id: 'treasure',
  title: '宝藏密室',
  description: '满屋的珍宝，但真正的宝物隐藏其中。',
  date: '2026-05-12',
  tags: ['迷宫', '观察'],
  portals: [
    { label: '回到来时路', description: '身后的门还未关闭', targetId: 'lockpick' },
    { label: '墙壁上出现了一个暗格', description: '似乎通向另一个空间', targetId: 'final' },
  ],
};

interface Props {
  room: RoomExport;
  baseUrl: string;
  portals: Portal[];
  nextPortal?: Portal;
}
const { room: meta, baseUrl, portals: externalPortals } = Astro.props;
---

<Layout title={`${meta.title} - 迷宫 - fffg`} description={meta.description} hideScrollButtons={true}>
  <MazeMap currentRoomId={meta.id} />
  <div class="blog-page">
    <article class="blog-article prose prose-zinc dark:prose-invert">
      <header class="mb-6 not-prose sm:mb-8">
        <h1 class="mb-3 text-2xl font-bold text-text sm:text-3xl">{meta.title}</h1>
        <div class="flex flex-wrap items-center gap-3">
          <time class="text-sm text-text-muted">{meta.date}</time>
          <span class="text-text-muted">·</span>
          <span class="inline-flex items-center gap-1 rounded-md bg-accent/10 px-2 py-0.5 text-xs text-accent">
            <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
            路由已加密
          </span>
        </div>
        {meta.tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {meta.tags.map((tag: string) => (
              <span class="rounded-full border border-border bg-card px-2.5 py-0.5 text-xs text-text-muted">#{tag}</span>
            ))}
          </div>
        )}
      </header>

      <PuzzleRoom room={meta} baseUrl={baseUrl} portals={externalPortals}>
        <div class="puzzle-area" id="puzzle-area">
          <div class="puzzle-atmosphere">
            <p>金币和珠宝堆积如山，但在角落里有三件与众不同的物品……</p>
          </div>
          <div class="puzzle-header">
            <h2 class="puzzle-title">🧩 谜题</h2>
          </div>
          <p class="puzzle-prompt">从以下物品中选出真正的宝物（可能不止一个）：</p>
          <div class="puzzle-items-grid">
            <button class="puzzle-item-btn" data-item-id="crown" data-selected="false">
              <span class="puzzle-item-icon">👑</span>
              <span class="puzzle-item-label">金色王冠</span>
            </button>
            <button class="puzzle-item-btn" data-item-id="mirror" data-selected="false">
              <span class="puzzle-item-icon">🪞</span>
              <span class="puzzle-item-label">古朴铜镜</span>
            </button>
            <button class="puzzle-item-btn" data-item-id="book" data-selected="false">
              <span class="puzzle-item-icon">📖</span>
              <span class="puzzle-item-label">泛黄古籍</span>
            </button>
            <button class="puzzle-item-btn" data-item-id="ring" data-selected="false">
              <span class="puzzle-item-icon">💍</span>
              <span class="puzzle-item-label">翡翠戒指</span>
            </button>
            <button class="puzzle-item-btn" data-item-id="lamp" data-selected="false">
              <span class="puzzle-item-icon">🪔</span>
              <span class="puzzle-item-label">生锈油灯</span>
            </button>
          </div>
          <div class="puzzle-items-actions">
            <button class="puzzle-btn puzzle-btn-primary" id="check-btn">确认选择</button>
            <p class="puzzle-hint" id="hint" style="display:none">💡 真正的宝物不是最闪耀的，而是最有知识的。</p>
          </div>
        </div>
      </PuzzleRoom>
    </article>
    <aside class="blog-toc-sidebar"></aside>
  </div>
</Layout>

<script>
  (function () {
    var correctIds = ['mirror', 'book'];
    var items = document.querySelectorAll('.puzzle-item-btn[data-item-id]');
    var checkBtn = document.getElementById('check-btn');
    var hintEl = document.getElementById('hint');
    var area = document.getElementById('puzzle-area');

    items.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var sel = btn.getAttribute('data-selected') === 'true';
        btn.setAttribute('data-selected', String(!sel));
        btn.classList.toggle('puzzle-item-selected');
      });
    });

    if (checkBtn) {
      checkBtn.addEventListener('click', function () {
        var selected = [];
        items.forEach(function (btn) {
          if (btn.getAttribute('data-selected') === 'true') {
            selected.push(btn.getAttribute('data-item-id') || '');
          }
        });
        var sorted = selected.slice().sort().join(',');
        var correct = correctIds.slice().sort().join(',');
        if (selected.length === correctIds.length && sorted === correct) {
          if (area) { area.style.opacity = '0'; area.style.transform = 'translateY(-20px)'; area.style.transition = 'all 0.5s ease'; setTimeout(function () { area.style.display = 'none'; }, 500); }
          if (window.fireConfetti) window.fireConfetti();
          setTimeout(function () { if (window.showPortals) window.showPortals(); }, 600);
        } else {
          if (hintEl) hintEl.style.display = 'block';
          items.forEach(function (btn) {
            btn.setAttribute('data-selected', 'false');
            btn.classList.remove('puzzle-item-selected');
          });
        }
      });
    }
  })();
</script>

<style>
  .puzzle-atmosphere {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    padding: 1rem 1.25rem;
    background: color-mix(in srgb, var(--color-accent) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    border-radius: 1rem;
  }
  .puzzle-atmosphere p {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 0;
  }
  .puzzle-items-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .puzzle-items-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 1rem;
  }
</style>
