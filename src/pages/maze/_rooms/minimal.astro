---
// ============================================================
// DEV 开发面板
//
// 自动发现所有 _rooms/*.astro 房间并列出跳转链接。
// 不参与迷宫图生成（portalSlots 为空），不在迷宫连接中。
// 新增房间后无需修改本文件。
// ============================================================
import MazeMap from '../../../components/MazeMap.astro';
import type { RoomExport, Portal } from '../../../data/maze';
import { getMazeUrl } from '../../../lib/maze-url';
import { mazeConfig } from '../../../data/maze-config.generated';

const title = 'DEV';
const description = '自动发现所有房间，方便开发快速跳转。';

export const room: RoomExport = {
  id: 'minimal',
  portalSlots: [],
};

interface Props {
  room: RoomExport;
  baseUrl: string;
  portals: Portal[];
}
const { room: meta, baseUrl } = Astro.props;

function portalHref(targetId: string): string {
  return `${baseUrl}${getMazeUrl(targetId, mazeConfig.mazeSalt)}`;
}

// 自动扫描所有房间文件，提取 room.id
const roomModules = import.meta.glob('/src/pages/maze/_rooms/*.astro', { eager: true });
const allRoomIds: string[] = Object.values(roomModules).map(
  (mod: unknown) => (mod as { room: RoomExport }).room.id,
);
const otherRoomIds = allRoomIds.filter((id) => id !== meta.id).sort();
---

<MazeMap currentRoomId={meta.id} />
<div class="minimal-page">
  <div class="minimal-container">
    <div class="minimal-badge">{title}</div>
    <h1 class="minimal-title">开发面板</h1>
    <p class="minimal-desc">{description}</p>
    <p class="minimal-count">{otherRoomIds.length} 个房间已注册</p>
    <div class="minimal-links">
      {
        otherRoomIds.map((id) => (
          <a href={portalHref(id)} class="minimal-link">
            <span class="minimal-link-label">{id}</span>
            <span class="minimal-link-arrow">&rarr;</span>
          </a>
        ))
      }
    </div>
  </div>
</div>

<style>
  .minimal-page {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
    padding: 2rem 1rem;
  }

  .minimal-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    text-align: center;
    max-width: 400px;
    width: 100%;
  }

  .minimal-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 700;
    color: #f59e0b;
    background: color-mix(in srgb, #f59e0b 15%, transparent);
    border: 1px solid color-mix(in srgb, #f59e0b 30%, transparent);
    border-radius: 9999px;
    letter-spacing: 0.05em;
  }

  .minimal-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .minimal-desc {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .minimal-count {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .minimal-links {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
  }

  .minimal-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .minimal-link:hover {
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
    border-color: var(--color-accent);
    transform: translateX(4px);
  }

  .minimal-link-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    flex: 1;
    text-align: left;
  }

  .minimal-link-arrow {
    font-size: 1.125rem;
    color: var(--color-accent);
    flex-shrink: 0;
  }
</style>
