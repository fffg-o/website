---
// 文章目录组件 - 客户端渲染，从 DOM 提取标题
// 桌面端：侧边栏，移动端：内容同步到抽屉中
---

<!-- 桌面端侧边栏目录 -->
<nav id="toc-nav" class="toc-nav">
  <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-text-muted">目录</h3>
  <ul id="toc-list" class="toc-list">
    <li class="text-sm text-text-muted">加载中...</li>
  </ul>
</nav>

<script>
  interface TocItem {
    id: string;
    text: string;
    tagName: string;
    level: number;
  }

  class TableOfContents {
    private listEl: HTMLElement;
    private headings: TocItem[] = [];
    private observer: IntersectionObserver | null = null;
    private activeId: string = '';
    private drawerContentEl: HTMLElement | null = null;

    constructor() {
      this.listEl = document.querySelector('#toc-list')!;
      this.drawerContentEl = document.getElementById('drawer-toc-content');
      this.init();
    }

    private init() {
      this.extractHeadings();
      this.render();
      this.setupObserver();
      this.syncToDrawer();
    }

    private extractHeadings() {
      const article = document.querySelector('.prose');
      if (!article) return;

      const elements = article.querySelectorAll('h2, h3');
      elements.forEach((el) => {
        const id = el.id || this.generateId(el.textContent || '');
        if (!el.id) el.id = id;

        this.headings.push({
          id,
          text: el.textContent || '',
          tagName: el.tagName,
          level: el.tagName === 'H2' ? 2 : 3,
        });
      });
    }

    private generateId(text: string): string {
      return text
        .toLowerCase()
        .replace(/[\s]+/g, '-')
        .replace(/[^\w\u4e00-\u9fff-]/g, '')
        .replace(/-+/g, '-');
    }

    private render() {
      if (this.headings.length === 0) {
        this.listEl.innerHTML = '<li class="text-sm text-text-muted">无目录</li>';
        return;
      }

      let html = '';
      for (const item of this.headings) {
        const isH3 = item.level === 3;
        html += `<li class="toc-item ${isH3 ? 'toc-item-h3' : 'toc-item-h2'}">
          <a href="#${item.id}" class="toc-link" data-id="${item.id}">${this.escapeHtml(item.text)}</a>
        </li>`;
      }
      this.listEl.innerHTML = html;

      // 平滑滚动 - 不关闭任何东西
      this.listEl.addEventListener('click', (e) => {
        const target = (e.target as HTMLElement).closest('a');
        if (!target) return;
        e.preventDefault();
        const id = target.getAttribute('href')?.slice(1);
        if (!id) return;
        const el = document.getElementById(id);
        if (el) {
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          window.history.pushState(null, '', `#${id}`);
        }
      });
    }

    private escapeHtml(text: string): string {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    private setupObserver() {
      if (this.headings.length === 0) return;

      const ids = this.headings.map((h) => h.id);

      this.observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              this.activeId = entry.target.id;
              this.updateActiveLink();
            }
          }
        },
        {
          rootMargin: '-80px 0px -50% 0px',
          threshold: 0,
        },
      );

      for (const id of ids) {
        const el = document.getElementById(id);
        if (el) this.observer.observe(el);
      }
    }

    private updateActiveLink() {
      // 更新桌面端侧边栏
      this.listEl.querySelectorAll('.toc-link').forEach((link) => {
        link.classList.remove('active');
        if (link.getAttribute('data-id') === this.activeId) {
          link.classList.add('active');
        }
      });
      // 更新抽屉内目录
      if (this.drawerContentEl) {
        this.drawerContentEl.querySelectorAll('.toc-link').forEach((link) => {
          link.classList.remove('active');
          if (link.getAttribute('data-id') === this.activeId) {
            link.classList.add('active');
          }
        });
      }
    }

    /** 将目录内容同步到移动端抽屉中 */
    private syncToDrawer() {
      if (!this.drawerContentEl) return;

      // 先隐藏整个目录区域，仅在真正有文章内容时才显示
      const drawerToc = document.getElementById('drawer-toc');
      if (!drawerToc) return;

      const article = document.querySelector('.prose');
      if (!article) {
        // 非文章页面：完全不显示目录区域
        drawerToc.classList.remove('active');
        return;
      }

      // 文章页面：显示目录区域
      drawerToc.classList.add('active');

      if (this.headings.length === 0) {
        this.drawerContentEl.innerHTML = '<p class="drawer-toc-empty">无目录</p>';
        return;
      }

      let html = '<ul class="toc-list">';
      for (const item of this.headings) {
        const isH3 = item.level === 3;
        html += `<li class="toc-item ${isH3 ? 'toc-item-h3' : 'toc-item-h2'}">
          <a href="#${item.id}" class="toc-link" data-id="${item.id}">${this.escapeHtml(item.text)}</a>
        </li>`;
      }
      html += '</ul>';
      this.drawerContentEl.innerHTML = html;

      // 点击抽屉内目录链接后关闭抽屉
      this.drawerContentEl.addEventListener('click', (e) => {
        const target = (e.target as HTMLElement).closest('a');
        if (!target) return;
        e.preventDefault();
        const id = target.getAttribute('href')?.slice(1);
        if (!id) return;
        const el = document.getElementById(id);
        if (el) {
          el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          window.history.pushState(null, '', `#${id}`);
        }
        // 关闭抽屉
        const drawer = document.getElementById('mobile-drawer');
        const overlay = document.getElementById('drawer-overlay');
        drawer?.classList.remove('open');
        overlay?.classList.remove('show');
        document.getElementById('menu-icon')?.classList.remove('hidden');
        document.getElementById('close-icon')?.classList.add('hidden');
        document.body.style.overflow = '';
      });
    }
  }

  // DOM 加载完成后初始化
  function initTOC() {
    if (!document.querySelector('#toc-list')) return;
    new TableOfContents();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTOC);
  } else {
    initTOC();
  }
</script>

<style is:global>
  .toc-nav {
    max-height: calc(100vh - 8rem);
    overflow-y: auto;
    padding: 0;
  }

  .toc-nav::-webkit-scrollbar {
    width: 4px;
  }
  .toc-nav::-webkit-scrollbar-thumb {
    background: var(--color-border);
    border-radius: 2px;
  }

  .toc-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .toc-item {
    line-height: 1.4;
  }

  .toc-item-h2 {
    padding-left: 0;
  }

  .toc-item-h3 {
    padding-left: 1rem;
  }

  .toc-link {
    display: block;
    padding: 0.25rem 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }

  .toc-link:hover {
    color: var(--color-text);
  }

  .toc-link.active {
    color: var(--color-primary);
    font-weight: 500;
  }

  /* 桌面端：无背景无色边线，融入页面 */
  @media (min-width: 1024px) {
    .toc-nav {
      width: auto;
      max-height: calc(100vh - 8rem);
      overflow-y: auto;
      background: none;
      border: none;
      padding: 0;
      box-shadow: none;
    }

    .toc-nav h3 {
      display: none;
    }

    .toc-link {
      padding: 0.2rem 0;
      border: none;
      border-radius: 0;
      background: none;
    }

    .toc-link:hover {
      background: none;
      border: none;
    }

    .toc-link.active {
      background: none;
      border: none;
      border-left: none;
    }
  }
</style>
