---
// 搜索组件 - 基于 Pagefind
// 提供搜索按钮和弹出搜索面板
---

<button
  id="search-toggle"
  class="search-toggle"
  aria-label="搜索文章"
  title="搜索文章"
>
  <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="11" cy="11" r="8"/>
    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
</button>

<div id="search-overlay" class="search-overlay hidden">
  <div class="search-modal">
    <div class="search-modal-header">
      <h3 class="text-lg font-semibold text-text">搜索文章</h3>
      <button id="search-close" class="search-close" aria-label="关闭搜索">
        <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    <div id="search-ui"></div>
  </div>
</div>

<script>
  class SearchManager {
    private toggleBtn: HTMLElement;
    private overlay: HTMLElement;
    private closeBtn: HTMLElement;
    private searchUI: HTMLElement;
    private pagefind: any = null;
    private uiInitialized = false;

    constructor() {
      this.toggleBtn = document.getElementById('search-toggle')!;
      this.overlay = document.getElementById('search-overlay')!;
      this.closeBtn = document.getElementById('search-close')!;
      this.searchUI = document.getElementById('search-ui')!;

      this.init();
    }

    private async init() {
      this.toggleBtn.addEventListener('click', () => this.open());
      this.closeBtn.addEventListener('click', () => this.close());

      // 点击 overlay 背景关闭
      this.overlay.addEventListener('click', (e) => {
        if (e.target === this.overlay) this.close();
      });

      // ESC 键关闭
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') this.close();
      });
    }

    private async open() {
      this.overlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';

      if (!this.uiInitialized) {
        await this.initPagefindUI();
        this.uiInitialized = true;
      }

      // 聚焦搜索输入框
      setTimeout(() => {
        const input = this.searchUI.querySelector('input');
        if (input) input.focus();
      }, 100);
    }

    private close() {
      this.overlay.classList.add('hidden');
      document.body.style.overflow = '';
    }

    private async initPagefindUI() {
      try {
        // 动态加载 Pagefind
        if (typeof PagefindUI === 'undefined') {
          await this.loadScript('/pagefind/pagefind-ui.js');
        }

        new PagefindUI({
          element: '#search-ui',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          bundlePath: '/pagefind/',
        });

      } catch (err) {
        console.warn('Pagefind UI 加载失败，请先执行构建', err);
        this.searchUI.innerHTML = `
          <div class="flex flex-col items-center justify-center py-12 text-text-muted">
            <svg class="mb-3 size-10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
              <line x1="8" y1="11" x2="14" y2="11"/>
            </svg>
            <p class="text-sm">搜索功能需要在构建后可用</p>
            <p class="mt-1 text-xs">请运行 <code class="rounded bg-border px-1 py-0.5">npm run build</code> 生成搜索索引</p>
          </div>
        `;
      }
    }

    private loadScript(src: string): Promise<void> {
      return new Promise((resolve, reject) => {
        const script = document.createElement('script');
        script.src = src;
        script.onload = () => resolve();
        script.onerror = () => reject(new Error(`Failed to load ${src}`));
        document.head.appendChild(script);
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => new SearchManager());
  } else {
    new SearchManager();
  }
</script>

<style is:global>
  .search-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.5rem;
    color: var(--color-text-muted);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s;
  }

  .search-toggle:hover {
    background: var(--color-border);
    color: var(--color-text);
  }

  /* 搜索弹窗 */
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 100;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 4rem 1rem 2rem;
  }

  .search-overlay.hidden {
    display: none;
  }

  .search-modal {
    width: 100%;
    max-width: 36rem;
    max-height: calc(100vh - 6rem);
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }

  .search-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--color-border);
  }

  .search-close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 0.375rem;
    color: var(--color-text-muted);
    background: transparent;
    border: none;
    cursor: pointer;
    transition: background-color 0.15s, color 0.15s;
  }

  .search-close:hover {
    background: var(--color-border);
    color: var(--color-text);
  }

  /* Pagefind 默认 UI 覆写 */
  #search-ui {
    padding: 1rem 1.25rem;
  }

  .pagefind-ui__search-input {
    border: 1px solid var(--color-border) !important;
    border-radius: 0.5rem !important;
    background: var(--color-surface) !important;
    color: var(--color-text) !important;
    padding: 0.75rem 1rem !important;
    font-size: 0.9375rem !important;
  }

  .pagefind-ui__search-input:focus {
    outline: none !important;
    border-color: var(--color-primary) !important;
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 20%, transparent) !important;
  }

  .pagefind-ui__result {
    border-bottom: 1px solid var(--color-border) !important;
    padding: 0.75rem 0 !important;
  }

  .pagefind-ui__result-title {
    color: var(--color-primary) !important;
    font-weight: 600 !important;
  }

  .pagefind-ui__result-excerpt {
    color: var(--color-text-muted) !important;
  }

  .pagefind-ui__search-clear {
    color: var(--color-text-muted) !important;
  }

  .pagefind-ui__message {
    color: var(--color-text-muted) !important;
    font-size: 0.8125rem !important;
  }
</style>
