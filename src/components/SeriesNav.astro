---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const seriesName = post.data.series;
const base = import.meta.env.BASE_URL;

// 构建系列列表数据（若无 series 字段则跳过）
const allPosts = await getCollection('blog');
const seriesPosts = seriesName
  ? allPosts
      .filter((p) => p.data.series === seriesName)
      .sort((a, b) => a.data.date.localeCompare(b.data.date))
  : [];

const currentIndex = seriesPosts.findIndex((p) => p.id === post.id);
const prevPost = currentIndex > 0 ? seriesPosts[currentIndex - 1] : null;
const nextPost = currentIndex < seriesPosts.length - 1 ? seriesPosts[currentIndex + 1] : null;
---

{seriesName && (
  <div class="series-nav">
    <div class="series-nav-header">
      <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a2.5 2.5 0 0 1 0-5H20"/>
      </svg>
      <span class="font-medium">系列：{seriesName}</span>
      <span class="text-xs text-text-muted">({currentIndex + 1}/{seriesPosts.length})</span>
    </div>

    <!-- 系列文章列表 -->
    <ul class="series-list">
      {seriesPosts.map((p, i) => (
        <li class={i === currentIndex ? 'series-item series-item-current' : 'series-item'}>
          <a href={`${base}/blog/${p.id.replace(/\.md$/, '')}`}>
            <span class="series-index">{i + 1}</span>
            <span>{p.data.title}</span>
          </a>
        </li>
      ))}
    </ul>

    <!-- 上一篇 / 下一篇 -->
    <div class="series-prev-next">
      <div class="series-prev">
        {prevPost ? (
          <a href={`${base}/blog/${prevPost.id.replace(/\.md$/, '')}`} class="series-prev-link">
            <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
            <div class="min-w-0">
              <span class="block text-xs text-text-muted">上一篇</span>
              <span class="block truncate text-sm font-medium">{prevPost.data.title}</span>
            </div>
          </a>
        ) : <div />}
      </div>
      <div class="series-next">
        {nextPost ? (
          <a href={`${base}/blog/${nextPost.id.replace(/\.md$/, '')}`} class="series-next-link">
            <div class="min-w-0 text-right">
              <span class="block text-xs text-text-muted">下一篇</span>
              <span class="block truncate text-sm font-medium">{nextPost.data.title}</span>
            </div>
            <svg class="size-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </a>
        ) : <div />}
      </div>
    </div>
  </div>
)}

<style is:global>
  .series-nav {
    margin-top: 2.5rem;
    padding: 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-card);
  }

  .series-nav-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .series-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
  }

  .series-item a {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.5rem;
    border-radius: 0.375rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: background-color 0.15s, color 0.15s;
  }

  .series-item a:hover {
    background: var(--color-border);
    color: var(--color-text);
  }

  .series-item-current a {
    color: var(--color-primary);
    font-weight: 500;
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
  }

  .series-index {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.25rem;
    height: 1.25rem;
    border-radius: 50%;
    font-size: 0.6875rem;
    font-weight: 600;
    background: var(--color-border);
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .series-item-current .series-index {
    background: var(--color-primary);
    color: white;
  }

  .series-prev-next {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }

  .series-prev,
  .series-next {
    flex: 1;
    min-width: 0;
  }

  .series-next {
    display: flex;
    justify-content: flex-end;
  }

  .series-prev-link,
  .series-next-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--color-text);
    transition: opacity 0.15s;
    max-width: 100%;
  }

  .series-prev-link:hover,
  .series-next-link:hover {
    opacity: 0.75;
  }

  .series-next-link {
    text-align: right;
  }
</style>
