---
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
// 取前3个项目
const featuredProjects = projects.slice(0, 3);
---

<section class="mb-16">
  <h2 class="mb-6 text-2xl font-bold text-text">精选项目</h2>
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {
      featuredProjects.map((project) => (
        <article class="group rounded-xl border border-border bg-card p-6 transition-all hover:border-primary/30 hover:shadow-md">
          <h3 class="mb-2 text-lg font-semibold text-text">
            {project.data.link ? (
              <a href={project.data.link} class="text-primary hover:underline">
                {project.data.title}
              </a>
            ) : (
              project.data.title
            )}
          </h3>
          <p class="mb-4 text-sm leading-relaxed text-text-muted">
            {project.data.description}
          </p>
          <div class="flex flex-wrap gap-2">
            {project.data.tags.map((tag: string) => (
              <span class="rounded-md bg-surface px-2.5 py-1 text-xs font-medium text-text-muted">
                {tag}
              </span>
            ))}
          </div>
        </article>
      ))
    }
  </div>
  <div class="mt-6 text-center">
    <a
      href="/projects"
      class="text-sm font-medium text-primary transition-colors hover:text-primary-dark"
    >
      查看全部项目 &rarr;
    </a>
  </div>
</section>
