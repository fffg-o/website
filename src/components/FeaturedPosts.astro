---
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');
// 取最新的3篇文章
const latestPosts = posts.sort((a, b) => b.data.date.localeCompare(a.data.date)).slice(0, 3);
---

<section class="mb-16">
  <h2 class="mb-6 text-2xl font-bold text-text">最新文章</h2>
  <div class="space-y-6">
    {
      latestPosts.map((post) => (
        <article class="group relative rounded-xl border border-border bg-card p-6 transition-all hover:border-primary/30 hover:shadow-md">
          <time class="mb-2 block text-xs text-text-muted">{post.data.date}</time>
          <h3 class="mb-2 text-lg font-semibold text-text">
            <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="after:absolute after:inset-0">
              {post.data.title}
            </a>
          </h3>
          <p class="text-sm leading-relaxed text-text-muted">
            {post.data.description}
          </p>
        </article>
      ))
    }
  </div>
  <div class="mt-6 text-center">
    <a
      href="/blog"
      class="text-sm font-medium text-primary transition-colors hover:text-primary-dark"
    >
      查看全部文章 &rarr;
    </a>
  </div>
</section>
