---
// ============================================================
// 迷宫地图组件
//
// 显示在迷宫房间页面右侧，动态展示玩家已访问的房间点位
// 及连接关系。仅渲染已访问节点，保证任意数量节点下的
// 可扩展性。
//
// 特性：
// 1. 每次进入迷宫（新标签页/会话）清除旧地图数据，重新记录
// 2. 地图组件可拖拽移动位置 + 自由缩放窗口大小
// 3. 沉浸式切换按钮可拖拽移动位置
// 4. 兼容性：地图数据来源自 maze-map.ts，新增房间页面无需修改本组件
// ============================================================
import { mazeGraph, VISITED_ROOMS_KEY, getNodeById } from '../data/maze-map';

interface Props {
  /** 当前房间 ID */
  currentRoomId: string;
}

const { currentRoomId } = Astro.props;

// 将地图数据序列化后传给客户端 JS，保证新增房间时无需修改本组件
const mazeGraphData = encodeURIComponent(JSON.stringify(mazeGraph));
// Server 端只渲染空容器，所有节点/连线由客户端 JS 动态构建
---

<!-- 地图容器（服务端仅渲染外壳，JS 动态填充） -->
<div class="maze-map" id="maze-map" data-current-room={currentRoomId} data-maze-graph={mazeGraphData}>
  <div class="maze-map-header" id="maze-map-header">
    <span class="maze-map-title">地图</span>
  </div>
  <div class="maze-map-body" id="maze-map-body">
    <svg id="maze-map-svg" class="maze-map-svg"></svg>
  </div>
  <!-- 缩放拖拽手柄 -->
  <div class="maze-map-resize-handle" id="maze-map-resize-handle">
    <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
      <path d="M12 0v12H0" stroke="currentColor" stroke-width="1.5" opacity="0.4"/>
      <path d="M12 4v8H4" stroke="currentColor" stroke-width="1.5" opacity="0.4"/>
      <path d="M12 8v4H8" stroke="currentColor" stroke-width="1.5" opacity="0.4"/>
    </svg>
  </div>
</div>

<!-- 移动端浮窗切换按钮（可拖拽） -->
<button
  id="maze-map-toggle"
  class="maze-map-toggle-btn"
  aria-label="切换地图"
  title="地图"
>
  🗺️
</button>

<!-- 移动端地图浮窗 -->
<div id="maze-map-overlay" class="maze-map-overlay">
  <div class="maze-map-overlay-content">
    <button id="maze-map-overlay-close" class="maze-map-overlay-close" aria-label="关闭地图">✕</button>
    <div id="maze-map-overlay-body"></div>
  </div>
</div>

<script>
  (function () {
    // ===== 常量 =====
    var VISITED_KEY = 'maze-visited-rooms';
    var MAP_POS_KEY = 'maze-map-position';
    var MAP_SIZE_KEY = 'maze-map-size';
    var BTN_POS_KEY = 'maze-btn-position';
    var SESSION_KEY = 'maze-session-active';

    var NODE_RADIUS = 8;
    var LABEL_OFFSET = 16;
    var PADDING = 16;

    var MAP_MIN_WIDTH = 140;
    var MAP_MIN_HEIGHT = 100;
    var MAP_MAX_WIDTH = 500;
    var MAP_MAX_HEIGHT = 600;

    // ===== 存储工具 =====
    function storeGet(key, def) {
      try { return JSON.parse(localStorage.getItem(key) || 'null') || def; }
      catch (e) { return def; }
    }
    function storeSet(key, val) {
      try { localStorage.setItem(key, JSON.stringify(val)); } catch (e) {}
    }

    // ===== Requirement 1: 新会话清除旧地图数据 =====
    function initSession() {
      if (!sessionStorage.getItem(SESSION_KEY)) {
        localStorage.removeItem(VISITED_KEY);
        localStorage.removeItem(MAP_POS_KEY);
        localStorage.removeItem(MAP_SIZE_KEY);
        localStorage.removeItem(BTN_POS_KEY);
        sessionStorage.setItem(SESSION_KEY, '1');
      }
    }

    // ===== 地图数据工具 =====
    function getVisitedRooms() {
      try { return JSON.parse(localStorage.getItem(VISITED_KEY) || '[]'); }
      catch (e) { return []; }
    }

    function recordVisit(roomId) {
      var visited = getVisitedRooms();
      if (visited.indexOf(roomId) === -1) {
        visited.push(roomId);
        localStorage.setItem(VISITED_KEY, JSON.stringify(visited));
      }
      return visited;
    }

    function buildVisitedData(allNodes, visitedSet) {
      var nodes = [];
      var nodeMap = {};
      allNodes.forEach(function (n) {
        if (visitedSet.has(n.id)) {
          nodes.push(n);
          nodeMap[n.id] = n;
        }
      });
      return { nodes: nodes, nodeMap: nodeMap };
    }

    function calcViewBox(nodes) {
      if (nodes.length === 0) {
        return { vb: '0 0 200 0', width: 200, height: 0 };
      }
      var minX = Infinity, minY = Infinity, maxX = -Infinity, maxY = -Infinity;
      nodes.forEach(function (n) {
        if (n.x < minX) minX = n.x;
        if (n.y < minY) minY = n.y;
        if (n.x > maxX) maxX = n.x;
        if (n.y > maxY) maxY = n.y;
      });
      var w = maxX - minX + PADDING * 2 + NODE_RADIUS * 2;
      var h = maxY - minY + PADDING * 2 + NODE_RADIUS * 2 + LABEL_OFFSET;
      var ox = minX - PADDING;
      var oy = minY - PADDING;
      return {
        vb: ox + ' ' + oy + ' ' + w + ' ' + h,
        width: Math.max(w, 100),
        height: Math.max(h, 40),
        ox: ox,
        oy: oy,
      };
    }

    function buildSvgHtml(visitedNodes, nodeMap, edges, currentRoomId) {
      var visitedSet = new Set(visitedNodes.map(function (n) { return n.id; }));
      if (visitedNodes.length === 0) return '';

      var lines = '';
      edges.forEach(function (edge) {
        var fromNode = nodeMap[edge.from];
        var toNode = nodeMap[edge.to];
        if (!fromNode || !toNode) return;
        lines += '<line'
          + ' x1="' + fromNode.x + '" y1="' + fromNode.y + '"'
          + ' x2="' + toNode.x + '" y2="' + toNode.y + '"'
          + ' stroke="var(--color-primary)" stroke-width="1.5"'
          + ' stroke-linecap="round" opacity="0.35"'
          + '/>';
      });

      var nodesHtml = '';
      visitedNodes.forEach(function (n) {
        var isCurrent = n.id === currentRoomId;
        var fill = isCurrent ? 'var(--color-primary)' : 'var(--color-card)';
        var stroke = 'var(--color-primary)';
        var strokeWidth = isCurrent ? '2.5' : '2';
        var labelFill = isCurrent ? 'var(--color-primary)' : 'var(--color-text)';
        nodesHtml += '<g class="maze-node-group'
          + (isCurrent ? ' current' : '')
          + '" data-room-id="' + n.id + '">'
          + '<circle cx="' + n.x + '" cy="' + n.y + '" r="' + NODE_RADIUS + '"'
          + ' fill="' + fill + '" stroke="' + stroke + '" stroke-width="' + strokeWidth + '"/>'
          + '<text x="' + n.x + '" y="' + (n.y + LABEL_OFFSET) + '"'
          + ' text-anchor="middle" dominant-baseline="central" font-size="7"'
          + ' fill="' + labelFill + '" font-weight="' + (isCurrent ? 'bold' : 'normal') + '">'
          + n.label + '</text>'
          + '</g>';
      });
      return lines + nodesHtml;
    }

    // ===== 主渲染函数 =====
    function renderMap(svgEl, currentRoomId, allNodes, edges) {
      var visited = recordVisit(currentRoomId);
      var visitedSet = new Set(visited);
      var data = buildVisitedData(allNodes, visitedSet);
      var viewBox = calcViewBox(data.nodes);

      var vbStr = viewBox.vb;
      svgEl.setAttribute('viewBox', vbStr);
      svgEl.setAttribute('preserveAspectRatio', 'xMidYMin meet');

      var innerHtml = buildSvgHtml(data.nodes, data.nodeMap, edges, currentRoomId);
      svgEl.innerHTML = innerHtml;
    }

    // ===== 沉浸式按钮点击逻辑（桌面端切换地图，移动端浮窗） =====
    function initToggleButton(currentRoomId, allNodes, edges) {
      var toggleBtn = document.getElementById('maze-map-toggle');
      var overlay = document.getElementById('maze-map-overlay');
      var closeBtn = document.getElementById('maze-map-overlay-close');
      var body = document.getElementById('maze-map-overlay-body');
      var mapEl = document.getElementById('maze-map');

      if (!toggleBtn) return;

      // 拖拽检测标记：如果用户拖动了按钮，则不触发点击
      var _wasDragged = false;
      var _dragDist = 0;
      var DRAG_THRESHOLD = 5; // px

      function onTogglePointerDown() {
        _wasDragged = false;
        _dragDist = 0;
      }

      function onTogglePointerMove() {
        _dragDist++;
        if (_dragDist > 2) _wasDragged = true;
      }

      function onToggleClick() {
        if (_wasDragged) return; // 拖拽时不触发点击

        var isMobile = window.innerWidth <= 1200;

        if (isMobile) {
          // 移动端：显示浮窗
          if (!overlay || !body) return;
          var visited = getVisitedRooms();
          var visitedSet = new Set(visited);
          var data = buildVisitedData(allNodes, visitedSet);
          var viewBox = calcViewBox(data.nodes);
          var innerHtml = buildSvgHtml(data.nodes, data.nodeMap, edges, currentRoomId);
          body.innerHTML = '<svg viewBox="' + viewBox.vb + '" class="maze-map-svg" preserveAspectRatio="xMidYMin meet">'
            + innerHtml + '</svg>';
          overlay.classList.add('open');
          document.body.style.overflow = 'hidden';
        } else {
          // 桌面端：切换地图显示/隐藏
          if (mapEl) {
            var isHidden = mapEl.style.display === 'none';
            mapEl.style.display = isHidden ? '' : 'none';
          }
        }
      }

      // 绑定拖拽检测事件（在常规拖动事件之前标记）
      toggleBtn.addEventListener('mousedown', onTogglePointerDown);
      toggleBtn.addEventListener('touchstart', onTogglePointerDown, { passive: true });
      document.addEventListener('mousemove', onTogglePointerMove);
      document.addEventListener('touchmove', onTogglePointerMove, { passive: true });

      // 点击事件（带拖拽检测）
      toggleBtn.addEventListener('click', onToggleClick);

      // 浮窗关闭
      if (closeBtn) closeBtn.addEventListener('click', function () {
        if (overlay) {
          overlay.classList.remove('open');
          document.body.style.overflow = '';
        }
      });
      if (overlay) {
        overlay.addEventListener('click', function (e) {
          if (e.target === overlay) {
            overlay.classList.remove('open');
            document.body.style.overflow = '';
          }
        });
      }
    }

    // ===== Requirement 2 & 3: 地图拖拽 + 缩放 =====
    function initMapDragAndResize() {
      var mapEl = document.getElementById('maze-map');
      var headerEl = document.getElementById('maze-map-header');
      var resizeHandle = document.getElementById('maze-map-resize-handle');
      if (!mapEl || !headerEl || !resizeHandle) return;

      // 恢复上次位置
      var savedPos = storeGet(MAP_POS_KEY, null);
      if (savedPos && typeof savedPos.x === 'number' && typeof savedPos.y === 'number') {
        mapEl.style.left = savedPos.x + 'px';
        mapEl.style.top = savedPos.y + 'px';
        mapEl.style.right = 'auto';
      }

      // 恢复上次大小
      var savedSize = storeGet(MAP_SIZE_KEY, null);
      if (savedSize && typeof savedSize.w === 'number' && typeof savedSize.h === 'number') {
        mapEl.style.width = savedSize.w + 'px';
        mapEl.style.height = savedSize.h + 'px';
      }

      // ---- 拖拽移动 ----
      var dragState = null;

      function onDragStart(e) {
        var clientX = e.clientX || (e.touches && e.touches[0].clientX);
        var clientY = e.clientY || (e.touches && e.touches[0].clientY);
        if (clientX == null) return;

        // 如果点击的是 resize handle，不触发拖拽
        if (e.target === resizeHandle || resizeHandle.contains(e.target)) return;

        var rect = mapEl.getBoundingClientRect();
        dragState = {
          startX: clientX,
          startY: clientY,
          origLeft: rect.left,
          origTop: rect.top,
        };
        mapEl.classList.add('maze-map-dragging');

        e.preventDefault();
      }

      function onDragMove(e) {
        if (!dragState) return;
        var clientX = e.clientX || (e.touches && e.touches[0].clientX);
        var clientY = e.clientY || (e.touches && e.touches[0].clientY);
        if (clientX == null) return;

        var dx = clientX - dragState.startX;
        var dy = clientY - dragState.startY;
        var newX = dragState.origLeft + dx;
        var newY = dragState.origTop + dy;

        // 边界约束：不允许拖出屏幕左侧/上侧
        newX = Math.max(0, newX);
        newY = Math.max(0, newY);

        mapEl.style.left = newX + 'px';
        mapEl.style.top = newY + 'px';
        mapEl.style.right = 'auto';
        mapEl.style.bottom = 'auto';

        e.preventDefault();
      }

      function onDragEnd() {
        if (!dragState) return;
        dragState = null;
        mapEl.classList.remove('maze-map-dragging');

        // 保存位置
        var left = parseFloat(mapEl.style.left);
        var top = parseFloat(mapEl.style.top);
        if (!isNaN(left) && !isNaN(top)) {
          storeSet(MAP_POS_KEY, { x: left, y: top });
        }
      }

      // 鼠标事件
      headerEl.addEventListener('mousedown', onDragStart);
      document.addEventListener('mousemove', onDragMove);
      document.addEventListener('mouseup', onDragEnd);

      // 触摸事件
      headerEl.addEventListener('touchstart', onDragStart, { passive: false });
      document.addEventListener('touchmove', onDragMove, { passive: false });
      document.addEventListener('touchend', onDragEnd);

      // ---- 缩放手柄 ----
      var resizeState = null;

      function onResizeStart(e) {
        var clientX = e.clientX || (e.touches && e.touches[0].clientX);
        var clientY = e.clientY || (e.touches && e.touches[0].clientY);
        if (clientX == null) return;

        var rect = mapEl.getBoundingClientRect();
        resizeState = {
          startX: clientX,
          startY: clientY,
          origW: rect.width,
          origH: rect.height,
        };
        mapEl.classList.add('maze-map-resizing');

        e.preventDefault();
        e.stopPropagation();
      }

      function onResizeMove(e) {
        if (!resizeState) return;
        var clientX = e.clientX || (e.touches && e.touches[0].clientX);
        var clientY = e.clientY || (e.touches && e.touches[0].clientY);
        if (clientX == null) return;

        var dx = clientX - resizeState.startX;
        var dy = clientY - resizeState.startY;
        var newW = Math.max(MAP_MIN_WIDTH, Math.min(MAP_MAX_WIDTH, resizeState.origW + dx));
        var newH = Math.max(MAP_MIN_HEIGHT, Math.min(MAP_MAX_HEIGHT, resizeState.origH + dy));

        mapEl.style.width = newW + 'px';
        mapEl.style.height = newH + 'px';

        e.preventDefault();
      }

      function onResizeEnd() {
        if (!resizeState) return;
        resizeState = null;
        mapEl.classList.remove('maze-map-resizing');

        // 保存大小
        var w = parseFloat(mapEl.style.width);
        var h = parseFloat(mapEl.style.height);
        if (!isNaN(w) && !isNaN(h)) {
          storeSet(MAP_SIZE_KEY, { w: w, h: h });
        }
      }

      resizeHandle.addEventListener('mousedown', onResizeStart);
      document.addEventListener('mousemove', onResizeMove);
      document.addEventListener('mouseup', onResizeEnd);

      resizeHandle.addEventListener('touchstart', onResizeStart, { passive: false });
      document.addEventListener('touchmove', onResizeMove, { passive: false });
      document.addEventListener('touchend', onResizeEnd);
    }

    // ===== Requirement 2: 切换按钮拖拽 =====
    function initToggleBtnDrag() {
      var btn = document.getElementById('maze-map-toggle');
      if (!btn) return;

      // 恢复上次位置
      var savedPos = storeGet(BTN_POS_KEY, null);
      if (savedPos && typeof savedPos.x === 'number' && typeof savedPos.y === 'number') {
        btn.style.left = savedPos.x + 'px';
        btn.style.top = savedPos.y + 'px';
        btn.style.bottom = 'auto';
        btn.style.right = 'auto';
      }

      var dragState = null;

      function onDragStart(e) {
        var clientX = e.clientX || (e.touches && e.touches[0].clientX);
        var clientY = e.clientY || (e.touches && e.touches[0].clientY);
        if (clientX == null) return;

        var rect = btn.getBoundingClientRect();
        dragState = {
          startX: clientX,
          startY: clientY,
          origLeft: rect.left,
          origTop: rect.top,
        };
        btn.classList.add('maze-map-toggle-dragging');

        e.preventDefault();
      }

      function onDragMove(e) {
        if (!dragState) return;
        var clientX = e.clientX || (e.touches && e.touches[0].clientX);
        var clientY = e.clientY || (e.touches && e.touches[0].clientY);
        if (clientX == null) return;

        var dx = clientX - dragState.startX;
        var dy = clientY - dragState.startY;
        var newX = Math.max(0, dragState.origLeft + dx);
        var newY = Math.max(0, dragState.origTop + dy);

        btn.style.left = newX + 'px';
        btn.style.top = newY + 'px';
        btn.style.bottom = 'auto';
        btn.style.right = 'auto';

        e.preventDefault();
      }

      function onDragEnd() {
        if (!dragState) return;
        dragState = null;
        btn.classList.remove('maze-map-toggle-dragging');

        var left = parseFloat(btn.style.left);
        var top = parseFloat(btn.style.top);
        if (!isNaN(left) && !isNaN(top)) {
          storeSet(BTN_POS_KEY, { x: left, y: top });
        }
      }

      btn.addEventListener('mousedown', onDragStart);
      document.addEventListener('mousemove', onDragMove);
      document.addEventListener('mouseup', onDragEnd);

      btn.addEventListener('touchstart', onDragStart, { passive: false });
      document.addEventListener('touchmove', onDragMove, { passive: false });
      document.addEventListener('touchend', onDragEnd);
    }

    // ===== 初始化 =====
    function init() {
      // Requirement 1: 新会话清除旧数据
      initSession();

      var mapEl = document.getElementById('maze-map');
      var svgEl = document.getElementById('maze-map-svg');
      var currentRoomId = mapEl ? mapEl.getAttribute('data-current-room') || '' : '';

      // 从 data-maze-graph 属性读取地图数据（来源自 maze-map.ts，保证兼容性）
      var graphRaw = mapEl ? mapEl.getAttribute('data-maze-graph') || '' : '';
      var graphData = graphRaw ? JSON.parse(decodeURIComponent(graphRaw)) : null;
      var allNodes = graphData ? graphData.nodes : [];
      var edges = graphData ? graphData.edges : [];

      if (svgEl) renderMap(svgEl, currentRoomId, allNodes, edges);

      // 沉浸式按钮（桌面端切换地图，移动端浮窗）
      initToggleButton(currentRoomId, allNodes, edges);

      // Requirement 2 & 3: 地图拖拽 + 缩放 + 按钮拖拽
      initMapDragAndResize();
      initToggleBtnDrag();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
</script>

<style>
  /* ===== 桌面端可拖拽地图（右侧） ===== */
  .maze-map {
    position: fixed;
    right: 1.5rem;
    top: 6rem;
    z-index: 30;
    width: 170px;
    min-width: 140px;
    min-height: 100px;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    transition: box-shadow 0.3s ease;
  }

  .dark .maze-map {
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.25);
  }

  .maze-map:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  .dark .maze-map:hover {
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.35);
  }

  .maze-map-dragging {
    opacity: 0.92;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.18) !important;
    transition: none !important;
    user-select: none !important;
  }

  .maze-map-resizing {
    user-select: none !important;
    transition: none !important;
  }

  .maze-map-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-accent) 4%, transparent);
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
  }

  .maze-map-header:active {
    cursor: grabbing;
  }

  /* 拖拽提示光标 */
  .maze-map-header::after {
    content: '⠿';
    font-size: 0.75rem;
    color: var(--color-text-muted);
    opacity: 0.3;
    margin-left: auto;
    padding-left: 0.5rem;
    line-height: 1;
  }

  .maze-map-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .maze-map-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.25rem;
    height: 1.125rem;
    padding: 0 0.375rem;
    font-size: 0.6875rem;
    font-weight: 700;
    color: white;
    background: var(--color-primary);
    border-radius: 999px;
    line-height: 1;
  }

  .maze-map-body {
    padding: 0.5rem;
    min-height: 2rem;
    overflow: hidden;
  }

  .maze-map-svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ===== 缩放手柄 ===== */
  .maze-map-resize-handle {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: 3px;
    cursor: nwse-resize;
    color: var(--color-text-muted);
    opacity: 0;
    transition: opacity 0.2s ease;
    z-index: 2;
  }

  .maze-map:hover .maze-map-resize-handle,
  .maze-map-resizing .maze-map-resize-handle {
    opacity: 0.7;
  }

  .maze-map-resize-handle:hover {
    opacity: 1 !important;
  }

  .maze-map-resize-handle svg {
    display: block;
  }

  /* 当前房间脉冲动画 */
  .maze-node-group.current circle {
    animation: map-pulse 2s ease-in-out infinite;
  }

  @keyframes map-pulse {
    0%, 100% { filter: brightness(1); }
    50% { filter: brightness(1.3); }
