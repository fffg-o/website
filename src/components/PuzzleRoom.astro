---
import { encryptSlug } from '../lib/slug-crypto';
import type { Portal, RoomExport } from '../data/maze';

interface Props {
  /** RoomExport —— 只需 id 和 portals，迷宫层不关心任何谜题细节 */
  room: RoomExport;
  baseUrl: string;
}

const { room, baseUrl } = Astro.props;

function portalHref(targetId: string): string {
  return `${baseUrl}/maze/${encryptSlug(targetId)}?from=${room.id}`;
}
---

<div class="puzzle-room" data-puzzle-id={room.id}>
  <!-- 房间具体内容（由每个 _room/*.astro 通过 slot 传入） -->
  <slot />

  <!-- 跳转链接（迷宫层唯一关心的部分） -->
  {
    room.portals.length > 0 && (
      <div class="puzzle-portals" id="puzzle-portals" style="display:none">
        <div class="puzzle-portals-glow"></div>
        <div class="puzzle-portals-content">
          <h3 class="puzzle-portals-title">🚪 可前往</h3>
          <div class="puzzle-portals-list">
            {
              room.portals.map((portal: Portal) => (
                <a href={portalHref(portal.targetId)} class="puzzle-portal-link">
                  <span class="puzzle-portal-icon">🚪</span>
                  <span class="puzzle-portal-info">
                    <span class="puzzle-portal-label">{portal.label}</span>
                    {portal.description && <span class="puzzle-portal-desc">{portal.description}</span>}
                  </span>
                  <span class="puzzle-portal-arrow">→</span>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    )
  }
</div>

<script>
  (function () {
    var qs = function (sel) { return document.querySelector(sel); };
    var el = function (id) { return document.getElementById(id); };

    /**
     * 由房间页面脚本调用：解谜成功后显示传送门
     */
    window.showPortals = function () {
      var ps = el('puzzle-portals');
      if (ps) {
        ps.style.display = 'block';
        setTimeout(function () {
          ps.classList.add('puzzle-portals-visible');
        }, 50);
      }
    };

    /**
     * 由房间页面脚本调用：触发彩色纸屑动画
     */
    window.fireConfetti = function () {
      var colors = ['#ff6b6b', '#feca57', '#48dbfb', '#ff9ff3', '#54a0ff', '#5f27cd'];
      for (var i = 0; i < 40; i++) {
        var piece = document.createElement('div');
        piece.className = 'confetti-piece';
        piece.style.left = Math.random() * 100 + 'vw';
        piece.style.background = colors[Math.floor(Math.random() * colors.length)];
        piece.style.width = (Math.random() * 8 + 4) + 'px';
        piece.style.height = (Math.random() * 8 + 4) + 'px';
        piece.style.animationDuration = (Math.random() * 2 + 1.5) + 's';
        piece.style.animationDelay = (Math.random() * 0.5) + 's';
        document.body.appendChild(piece);
        setTimeout(function () { piece.remove(); }, 3000);
      }
    };
  })();
</script>

<style>
  .puzzle-room {
    max-width: 600px;
    margin: 0 auto;
    padding: 1.5rem 0;
  }

  /* ===== 传送门区域 ===== */
  .puzzle-portals {
    display: none;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    margin-top: 2rem;
  }

  .puzzle-portals-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .puzzle-portals-glow {
    height: 4px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-accent), #22c55e, var(--color-primary));
    background-size: 300% 100%;
    border-radius: 2px;
    margin-bottom: 1.5rem;
    animation: shimmer 2s linear infinite;
  }

  @keyframes shimmer {
    0% { background-position: 0% 0; }
    100% { background-position: 300% 0; }
  }

  .puzzle-portals-content {
    text-align: center;
    padding: 2rem 1.5rem;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
  }

  .puzzle-portals-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
  }

  .puzzle-portals-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .puzzle-portal-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.25rem;
    background: color-mix(in srgb, var(--color-accent) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 20%, transparent);
    border-radius: 0.75rem;
    text-decoration: none;
    transition: all 0.2s;
  }

  .puzzle-portal-link:hover {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border-color: var(--color-accent);
    transform: translateX(4px);
  }

  .puzzle-portal-icon { font-size: 1.5rem; flex-shrink: 0; }
  .puzzle-portal-info { display: flex; flex-direction: column; gap: 0.125rem; flex: 1; min-width: 0; }
  .puzzle-portal-label { font-size: 1rem; font-weight: 600; color: var(--color-text); }
  .puzzle-portal-desc { font-size: 0.8125rem; color: var(--color-text-muted); }
  .puzzle-portal-arrow { font-size: 1.25rem; color: var(--color-accent); flex-shrink: 0; transition: transform 0.2s; }
  .puzzle-portal-link:hover .puzzle-portal-arrow { transform: translateX(4px); }

  /* ===== 通用谜题样式（房间页面可复用） ===== */
  .puzzle-area {
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.5rem;
    transition: all 0.5s ease;
  }

  .puzzle-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .puzzle-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--color-text);
  }

  .puzzle-prompt {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text);
    margin-bottom: 1.25rem;
  }

  .puzzle-hint {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: #f59e0b;
    animation: fade-in 0.3s ease-out;
  }

  .puzzle-btn {
    padding: 0.625rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    border: none;
    border-radius: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
    align-self: flex-start;
  }

  .puzzle-btn-primary { background: var(--color-primary); color: white; }
  .puzzle-btn-primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .puzzle-btn-primary:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .puzzle-btn-secondary { background: color-mix(in srgb, var(--color-border) 50%, transparent); color: var(--color-text); }
  .puzzle-btn-secondary:hover { background: var(--color-border); }

  .puzzle-input {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    border: 2px solid var(--color-border);
    border-radius: 0.75rem;
    background: var(--color-surface);
    color: var(--color-text);
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    box-sizing: border-box;
  }

  .puzzle-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 20%, transparent);
  }

  .puzzle-input-error { animation: shake 0.4s ease; border-color: #ef4444 !important; }

  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-6px); }
    50% { transform: translateX(6px); }
    75% { transform: translateX(-4px); }
  }

  .puzzle-success-icon {
    font-size: 3rem;
    margin-bottom: 0.75rem;
    animation: success-bounce 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  @keyframes success-bounce {
    0% { transform: scale(0) rotate(-30deg); }
    60% { transform: scale(1.2) rotate(5deg); }
    100% { transform: scale(1) rotate(0deg); }
  }

  .puzzle-success-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
  }

  .puzzle-success-text {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .puzzle-item-btn {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 100%;
    padding: 0.875rem 1rem;
    background: var(--color-surface);
    border: 2px solid var(--color-border);
    border-radius: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
    text-align: left;
    font-size: 0.9375rem;
    color: var(--color-text);
  }

  .puzzle-item-btn:hover {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 5%, transparent);
  }

  .puzzle-item-btn.puzzle-item-selected {
    border-color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 30%, transparent);
  }

  .puzzle-item-icon {
    font-size: 1.5rem;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-card);
    border-radius: 0.625rem;
    flex-shrink: 0;
  }

  .puzzle-item-label { font-weight: 500; }

  @media (max-width: 639px) {
    .puzzle-room { padding: 1rem 0; }
    .puzzle-area { padding: 1.25rem; border-radius: 0.75rem; }
    .puzzle-portals-content { padding: 1.5rem 1rem; }
    .puzzle-portal-link { padding: 0.75rem 1rem; }
  }
</style>
